---
import Layout from '../layouts/Layout.astro';
import { siteConfig } from '../data/locations';
---

<Layout
  title="Contacto | MHK Studio"
  description="Contacta con MHK Studio, estudio de diseño de interiores en Mojácar. Cuéntanos tu proyecto y te responderemos en menos de 24 horas."
  canonical={`${siteConfig.url}/contacto`}
>
  <!-- Hero -->
  <section class="relative h-[50vh] min-h-[350px] flex items-end pb-16 overflow-hidden">
    <div class="absolute inset-0">
      <img src="/images/PortadaContacto.webp" alt="Contacto MHK Studio" class="w-full h-full object-cover" loading="eager" />
      <div class="absolute inset-0 bg-[#201400]/50"></div>
    </div>
    <div class="relative z-10 max-w-6xl mx-auto px-6 w-full">
      <p class="text-xs tracking-[0.4em] uppercase text-[#bda589] mb-3">Estamos aquí</p>
      <h1 class="text-4xl md:text-5xl font-light text-white">Contáctanos</h1>
    </div>
  </section>

  <!-- Contact section -->
  <section class="py-24 px-6 bg-[#fdfaf7]">
    <div class="max-w-6xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-16">

      <!-- Info -->
      <div>
        <p class="text-xs tracking-[0.4em] uppercase text-[#bda589] mb-8">Información de contacto</p>
        <div class="space-y-8">
          <div>
            <p class="text-xs uppercase tracking-widest text-[#bda589]/70 mb-2">Teléfono</p>
            <a href={siteConfig.phoneHref} class="text-xl font-light text-[#201400] hover:text-[#bda589] transition-colors">
              {siteConfig.phone}
            </a>
          </div>
          <div>
            <p class="text-xs uppercase tracking-widest text-[#bda589]/70 mb-2">Email</p>
            <a href={`mailto:${siteConfig.email}`} class="text-xl font-light text-[#201400] hover:text-[#bda589] transition-colors">
              {siteConfig.email}
            </a>
          </div>
          <div>
            <p class="text-xs uppercase tracking-widest text-[#bda589]/70 mb-2">Dirección</p>
            <p class="text-lg font-light text-[#201400]">{siteConfig.address}</p>
          </div>
          <div>
            <p class="text-xs uppercase tracking-widest text-[#bda589]/70 mb-4">Redes sociales</p>
            <div class="flex flex-col gap-3">
              <a href={siteConfig.whatsapp} target="_blank" rel="noopener" class="flex items-center gap-3 text-sm text-[#201400]/70 hover:text-[#bda589] transition-colors">
                <span class="w-8 h-px bg-[#bda589]/40"></span>WhatsApp
              </a>
              <a href={siteConfig.instagram} target="_blank" rel="noopener" class="flex items-center gap-3 text-sm text-[#201400]/70 hover:text-[#bda589] transition-colors">
                <span class="w-8 h-px bg-[#bda589]/40"></span>Instagram
              </a>
              <a href={siteConfig.facebook} target="_blank" rel="noopener" class="flex items-center gap-3 text-sm text-[#201400]/70 hover:text-[#bda589] transition-colors">
                <span class="w-8 h-px bg-[#bda589]/40"></span>Facebook
              </a>
              <a href={siteConfig.pinterest} target="_blank" rel="noopener" class="flex items-center gap-3 text-sm text-[#201400]/70 hover:text-[#bda589] transition-colors">
                <span class="w-8 h-px bg-[#bda589]/40"></span>Pinterest
              </a>
            </div>
          </div>
          <a
            href={siteConfig.whatsapp}
            target="_blank"
            rel="noopener"
            class="inline-block border border-[#bda589] px-8 py-4 text-xs uppercase text-[#201400] transition-all hover:bg-[#bda589] hover:text-white"
          >
            Escribir por WhatsApp
          </a>
        </div>
      </div>

      <!-- Form -->
      <div>
        <p class="text-xs tracking-[0.4em] uppercase text-[#bda589] mb-8">Cuéntanos tu proyecto</p>
        <form
          action="/gracias"
          method="POST"
          class="space-y-6"
          name="contacto"
          data-netlify="true"
        >
          <input type="hidden" name="form-name" value="contacto" />
          <div>
            <label for="nombre" class="block text-xs uppercase tracking-widest text-[#201400]/60 mb-2">Nombre *</label>
            <input
              id="nombre"
              type="text"
              name="nombre"
              autocomplete="name"
              required
              class="w-full border-b border-[#201400]/20 bg-transparent py-3 text-[#201400] text-sm outline-none focus:border-[#bda589] transition-colors placeholder:text-[#201400]/30"
              placeholder="Tu nombre"
            />
          </div>
          <div>
            <label for="email" class="block text-xs uppercase tracking-widest text-[#201400]/60 mb-2">Email *</label>
            <input
              id="email"
              type="email"
              name="email"
              autocomplete="email"
              required
              class="w-full border-b border-[#201400]/20 bg-transparent py-3 text-[#201400] text-sm outline-none focus:border-[#bda589] transition-colors placeholder:text-[#201400]/30"
              placeholder="tu@email.com"
            />
          </div>
          <div>
            <label for="telefono" class="block text-xs uppercase tracking-widest text-[#201400]/60 mb-2">Teléfono</label>
            <input
              id="telefono"
              type="tel"
              name="telefono"
              autocomplete="tel"
              class="w-full border-b border-[#201400]/20 bg-transparent py-3 text-[#201400] text-sm outline-none focus:border-[#bda589] transition-colors placeholder:text-[#201400]/30"
              placeholder="+34 600 000 000"
            />
          </div>
          <div>
            <label for="servicio" class="block text-xs uppercase tracking-widest text-[#201400]/60 mb-2">Servicio de interés</label>
            <select
              id="servicio"
              name="servicio"
              class="w-full border-b border-[#201400]/20 bg-transparent py-3 text-[#201400] text-sm outline-none focus:border-[#bda589] transition-colors"
            >
              <option value="">Selecciona un servicio</option>
              <option>Decoración de interiores</option>
              <option>Proyecto de interiorismo</option>
              <option>Diseño de cocinas y baños</option>
              <option>Home Staging</option>
              <option>Asesoría online</option>
              <option>Otro</option>
            </select>
          </div>
          <div>
            <label for="mensaje" class="block text-xs uppercase tracking-widest text-[#201400]/60 mb-2">Tu proyecto *</label>
            <textarea
              id="mensaje"
              name="mensaje"
              required
              rows="5"
              class="w-full border-b border-[#201400]/20 bg-transparent py-3 text-[#201400] text-sm outline-none focus:border-[#bda589] transition-colors resize-none placeholder:text-[#201400]/30"
              placeholder="Cuéntanos brevemente qué tienes en mente..."
            ></textarea>
          </div>
          <div class="flex items-start gap-3">
            <input type="checkbox" id="privacidad" name="privacidad" required class="mt-1 accent-[#bda589]" />
            <label for="privacidad" class="text-xs text-[#201400]/60 leading-relaxed">
              He leído y acepto la <a href="/politica-de-privacidad" class="underline hover:text-[#bda589]">política de privacidad</a>
            </label>
          </div>
          <button
            type="submit"
            class="w-full bg-[#201400] text-white text-xs tracking-[0.3em] uppercase py-4 hover:bg-[#bda589] transition-colors duration-300"
          >
            Enviar mensaje
          </button>
        </form>
      </div>
    </div>
  </section>
</Layout>
