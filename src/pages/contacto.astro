---
import Layout from '../layouts/Layout.astro';
import { siteConfig } from '../data/locations';

const contactSocialLinks = [
  {
    label: 'Instagram',
    href: siteConfig.instagram,
    icon: '<rect x="4" y="4" width="16" height="16" rx="5" ry="5"></rect><path d="M16.2 11.37a4.2 4.2 0 1 1-8.4 0 4.2 4.2 0 0 1 8.4 0Z"></path><path d="M17.5 6.5h.01"></path>',
  },
  {
    label: 'Facebook',
    href: siteConfig.facebook,
    icon: '<path d="M14 8h2.2V4.4A24.8 24.8 0 0 0 13 4c-3.16 0-5.32 1.93-5.32 5.45V12H4.2v4h3.48v8h4.26v-8h3.34l.53-4h-3.87V9.85C11.94 8.7 12.25 8 14 8Z" />',
  },
  {
    label: 'Pinterest',
    href: siteConfig.pinterest,
    icon: '<path d="M12.04 2.5a9.5 9.5 0 0 0-3.46 18.35c-.08-.79-.16-2 .03-2.86l1.1-4.67s-.28-.57-.28-1.4c0-1.32.76-2.3 1.7-2.3.8 0 1.2.6 1.2 1.33 0 .81-.52 2.03-.79 3.16-.22.94.47 1.7 1.4 1.7 1.68 0 2.98-1.78 2.98-4.34 0-2.27-1.63-3.86-3.96-3.86-2.7 0-4.29 2.02-4.29 4.12 0 .81.31 1.68.7 2.15.08.1.09.18.07.28l-.26 1.06c-.04.17-.14.2-.32.12-1.2-.56-1.95-2.32-1.95-3.74 0-3.04 2.2-5.82 6.35-5.82 3.34 0 5.93 2.38 5.93 5.55 0 3.32-2.1 5.99-5 5.99-.98 0-1.9-.5-2.2-1.1l-.6 2.29c-.22.86-.81 1.93-1.2 2.58A9.5 9.5 0 1 0 12.04 2.5Z" />',
  },
];
---

<Layout
  title="Contacto | MHK Studio"
  description="Contacta con MHK Studio, estudio de diseño de interiores en Mojácar. Cuéntanos tu proyecto y te responderemos en menos de 24 horas."
  canonical={`${siteConfig.url}/contacto`}
>
  <!-- Hero -->
  <section class="relative flex min-h-[58vh] items-center justify-center overflow-hidden px-6 py-20 text-center md:min-h-[66vh]">
    <div class="absolute inset-0">
      <img src="/images/Contacto.png" alt="Contacto MHK Studio" class="h-full w-full object-cover" loading="eager" />
    </div>
    <div class="relative z-10 mx-auto max-w-4xl">
      <h1 class="text-[clamp(2rem,10vw,3.75rem)] font-light leading-tight text-[#120c00]">
        ¿Tienes un proyecto en mente o deseas renovar tu hogar?
      </h1>
    </div>
  </section>

  <!-- Intro -->
  <section class="bg-white px-6 py-20">
    <div class="mx-auto max-w-[1500px]">
      <p class="mx-auto max-w-4xl text-center text-lg font-light leading-relaxed text-[#120c00]">
        En <span class="text-[#d4c0ab]">MHK Studio</span> estamos listos para ayudarte a transformar tu espacio en un lugar único, funcional y con alma.
      </p>
      <div class="mt-20 h-px w-full bg-[#bda589]/65"></div>
    </div>
  </section>

  <!-- Contact section -->
  <section class="px-6 pb-24 bg-white">
    <div class="max-w-6xl mx-auto">
      <!-- Map -->
      <div class="mb-20">
        <div class="overflow-hidden border border-[#bda589]/30 bg-white shadow-[0_18px_45px_rgba(32,20,0,0.08)]">
          <iframe
            src="https://www.google.com/maps?q=Calle%20la%20Mata%2C%20Moj%C3%A1car%2C%20Almer%C3%ADa%2C%20Espa%C3%B1a&output=embed"
            title="Ubicación de MHK Studio en Mojácar"
            class="h-[360px] w-full md:h-[430px]"
            style="border:0;"
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
          ></iframe>
        </div>
      </div>

      <div id="formulario" class="grid scroll-mt-28 grid-cols-1 gap-16 md:grid-cols-2">

      <!-- Info -->
      <div>
        <p class="text-xs tracking-[0.4em] uppercase text-[#bda589] mb-8">Información de contacto</p>
        <div class="space-y-8">
          <div>
            <p class="text-xs uppercase tracking-widest text-[#bda589]/70 mb-2">Teléfono</p>
            <a href={siteConfig.phoneHref} class="text-xl font-light text-[#201400] hover:text-[#bda589] transition-colors">
              {siteConfig.phone}
            </a>
          </div>
          <div>
            <p class="text-xs uppercase tracking-widest text-[#bda589]/70 mb-2">Email</p>
            <a href={`mailto:${siteConfig.email}`} class="text-xl font-light text-[#201400] hover:text-[#bda589] transition-colors">
              {siteConfig.email}
            </a>
          </div>
          <div>
            <p class="text-xs uppercase tracking-widest text-[#bda589]/70 mb-2">Dirección</p>
            <p class="text-lg font-light text-[#201400]">{siteConfig.address}</p>
          </div>
          <div>
            <p class="text-xs uppercase tracking-widest text-[#bda589]/70 mb-4">Redes sociales</p>
            <div class="flex flex-col gap-3">
              {contactSocialLinks.map((link) => (
                <a href={link.href} target="_blank" rel="noopener" class="flex items-center gap-3 text-sm text-[#201400]/70 hover:text-[#bda589] transition-colors">
                  <span class="grid h-5 w-5 place-items-center text-[#bda589]" aria-hidden="true">
                    <svg
                      viewBox="0 0 24 24"
                      class="h-4 w-4"
                      fill={link.label === 'Instagram' ? 'none' : 'currentColor'}
                      stroke={link.label === 'Instagram' ? 'currentColor' : 'none'}
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      set:html={link.icon}
                    />
                  </span>
                  {link.label}
                </a>
              ))}
            </div>
          </div>
          <a
            href={siteConfig.whatsapp}
            target="_blank"
            rel="noopener"
            class="inline-block border border-[#bda589] px-8 py-4 text-xs uppercase text-[#201400] transition-all hover:bg-[#bda589] hover:text-white"
          >
            Escribir por WhatsApp
          </a>
        </div>
      </div>

      <!-- Form -->
      <div>
        <p class="text-xs tracking-[0.4em] uppercase text-[#bda589] mb-8">Cuéntanos tu proyecto</p>
        <form
          action="/gracias"
          method="POST"
          class="space-y-6"
          name="contacto"
          data-netlify="true"
        >
          <input type="hidden" name="form-name" value="contacto" />
          <div>
            <label for="nombre" class="block text-xs uppercase tracking-widest text-[#201400]/60 mb-2">Nombre *</label>
            <input
              id="nombre"
              type="text"
              name="nombre"
              autocomplete="name"
              required
              class="w-full border-b border-[#201400]/20 bg-transparent py-3 text-[#201400] text-sm outline-none focus:border-[#bda589] transition-colors placeholder:text-[#201400]/30"
              placeholder="Tu nombre"
            />
          </div>
          <div>
            <label for="email" class="block text-xs uppercase tracking-widest text-[#201400]/60 mb-2">Email *</label>
            <input
              id="email"
              type="email"
              name="email"
              autocomplete="email"
              required
              class="w-full border-b border-[#201400]/20 bg-transparent py-3 text-[#201400] text-sm outline-none focus:border-[#bda589] transition-colors placeholder:text-[#201400]/30"
              placeholder="tu@email.com"
            />
          </div>
          <div>
            <label for="telefono" class="block text-xs uppercase tracking-widest text-[#201400]/60 mb-2">Teléfono</label>
            <input
              id="telefono"
              type="tel"
              name="telefono"
              autocomplete="tel"
              class="w-full border-b border-[#201400]/20 bg-transparent py-3 text-[#201400] text-sm outline-none focus:border-[#bda589] transition-colors placeholder:text-[#201400]/30"
              placeholder="+34 600 000 000"
            />
          </div>
          <div>
            <label for="servicio" class="block text-xs uppercase tracking-widest text-[#201400]/60 mb-2">Servicio de interés</label>
            <select
              id="servicio"
              name="servicio"
              class="w-full border-b border-[#201400]/20 bg-transparent py-3 text-[#201400] text-sm outline-none focus:border-[#bda589] transition-colors"
            >
              <option value="">Selecciona un servicio</option>
              <option>Decoración de interiores</option>
              <option>Proyecto de interiorismo</option>
              <option>Diseño de cocinas y baños</option>
              <option>Home Staging</option>
              <option>Asesoría online</option>
              <option>Otro</option>
            </select>
          </div>
          <div>
            <label for="mensaje" class="block text-xs uppercase tracking-widest text-[#201400]/60 mb-2">Tu proyecto *</label>
            <textarea
              id="mensaje"
              name="mensaje"
              required
              rows="5"
              class="w-full border-b border-[#201400]/20 bg-transparent py-3 text-[#201400] text-sm outline-none focus:border-[#bda589] transition-colors resize-none placeholder:text-[#201400]/30"
              placeholder="Cuéntanos brevemente qué tienes en mente..."
            ></textarea>
          </div>
          <div class="flex items-start gap-3">
            <input type="checkbox" id="privacidad" name="privacidad" required class="mt-1 accent-[#bda589]" />
            <label for="privacidad" class="text-xs text-[#201400]/60 leading-relaxed">
              He leído y acepto la <a href="/politica-de-privacidad" class="underline hover:text-[#bda589]">política de privacidad</a>
            </label>
          </div>
          <button
            type="submit"
            class="w-full bg-[#201400] text-white text-xs tracking-[0.3em] uppercase py-4 hover:bg-[#bda589] transition-colors duration-300"
          >
            Enviar mensaje
          </button>
        </form>
      </div>
      </div>
    </div>
  </section>
</Layout>
