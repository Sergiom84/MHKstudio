---
import Layout from '../layouts/Layout.astro';
import { locations, services, brandLogos, siteConfig } from '../data/locations';

export function getStaticPaths() {
  return locations.map(loc => ({
    params: { ciudad: loc.slug },
    props: { location: loc },
  }));
}

const { location } = Astro.props;

const schema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "@id": `${siteConfig.url}/${location.slug}/`,
  "url": `${siteConfig.url}/${location.slug}/`,
  "name": location.title,
  "description": location.metaDescription,
  "isPartOf": { "@id": `${siteConfig.url}/#website` },
  "inLanguage": "es",
  "breadcrumb": {
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Inicio", "item": siteConfig.url },
      { "@type": "ListItem", "position": 2, "name": location.title }
    ]
  }
};
---

<Layout
  title={location.title}
  description={location.metaDescription}
  canonical={`${siteConfig.url}/${location.slug}`}
  schema={schema}
>
  <!-- Hero -->
  <section class="relative h-[60vh] min-h-[420px] flex items-end pb-16 overflow-hidden">
    <div class="absolute inset-0">
      <img
        src="/images/PortadaInicio-1.webp"
        alt={`Diseñadora de interiores en ${location.city}`}
        class="w-full h-full object-cover"
        loading="eager"
      />
      <div class="absolute inset-0 bg-[#201400]/50"></div>
    </div>
    <div class="relative z-10 max-w-6xl mx-auto px-6 w-full">
      <nav class="text-xs text-white/50 mb-6 flex gap-2">
        <a href="/" class="hover:text-[#bda589] transition-colors">Inicio</a>
        <span>/</span>
        <span class="text-white/80">{location.title}</span>
      </nav>
      <p class="text-xs tracking-[0.4em] uppercase text-[#bda589] mb-3">designing for living</p>
      <h1 class="text-4xl md:text-5xl font-light text-white leading-tight max-w-2xl">
        {location.title}
      </h1>
    </div>
  </section>

  <!-- Intro -->
  <section class="py-24 px-6 bg-[#fdfaf7]">
    <div class="max-w-4xl mx-auto text-center">
      <h2 class="text-2xl md:text-3xl font-light text-[#201400] mb-8 leading-relaxed">
        Diseño de interiores personalizado en {location.city}
      </h2>
      <p class="text-base text-[#201400]/65 leading-relaxed max-w-2xl mx-auto">
        En MHK Studio somos un estudio de diseño de interiores apasionado por crear espacios únicos, funcionales y con alma. Trabajamos en {location.city} ({location.province}) y toda la zona, diseñando ambientes que reflejan la personalidad y el estilo de vida de cada cliente.
      </p>
    </div>
  </section>

  <!-- Services -->
  <section class="py-20 px-6 bg-white">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-14">
        <p class="text-xs tracking-[0.4em] uppercase text-[#bda589] mb-4">Nuestros servicios en {location.city}</p>
        <h2 class="text-3xl font-light text-[#201400]">¿En qué podemos ayudarte?</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {services.map(service => (
          <article class="bg-[#fdfaf7] overflow-hidden group">
            <div class="aspect-[4/3] overflow-hidden">
              <img
                src={service.image}
                alt={`${service.title} en ${location.city}`}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
                loading="lazy"
              />
            </div>
            <div class="p-6">
              <h3 class="text-base font-medium text-[#201400] mb-2">{service.title}</h3>
              <p class="text-sm text-[#201400]/60 leading-relaxed">{service.description}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Brands -->
  <section class="py-16 px-6 bg-[#fdfaf7]">
    <div class="max-w-6xl mx-auto">
      <p class="text-center text-xs tracking-[0.4em] uppercase text-[#bda589] mb-10">Trabajamos con las mejores marcas</p>
      <div class="flex flex-wrap justify-center items-center gap-8">
        {brandLogos.slice(0, 10).map(logo => (
          <img src={logo.src} alt={logo.name} class="h-7 w-auto object-contain grayscale opacity-50 hover:opacity-100 hover:grayscale-0 transition-all duration-300" loading="lazy" />
        ))}
      </div>
    </div>
  </section>

  <!-- Local SEO content -->
  <section class="py-24 px-6 bg-white">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl md:text-3xl font-light text-[#201400] mb-8">
        Tu estudio de diseño de interiores en {location.city}
      </h2>
      <div class="space-y-5 text-base text-[#201400]/65 leading-relaxed">
        <p>
          MHK Studio es tu estudio de referencia para el diseño de interiores en {location.city} ({location.province}). Combinamos estética, funcionalidad y atención personalizada para crear espacios que realmente te representen.
        </p>
        <p>
          Ofrecemos servicios completos de interiorismo en {location.city}: desde la decoración de ambientes hasta proyectos llave en mano, diseño de cocinas y baños a medida, home staging profesional y asesoría online.
        </p>
        <p>
          Nos desplazamos a {location.city} y a toda la zona. Nuestro proceso comienza con una visita gratuita al espacio para entender tus necesidades, estilo y presupuesto, y termina con un proyecto que supera tus expectativas.
        </p>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-24 px-6 bg-[#bda589]">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="text-3xl font-light text-white mb-6">¿Transformamos tu espacio en {location.city}?</h2>
      <p class="text-white/85 mb-10 font-light leading-relaxed">
        Cuéntanos tu proyecto. Te responderemos en menos de 24 horas.
      </p>
      <div class="flex flex-col items-center justify-center gap-3 sm:flex-row">
        <a href="/contacto" class="inline-block w-full bg-white text-center text-[#201400] text-xs uppercase px-10 py-4 hover:bg-[#201400] hover:text-white transition-all duration-300 sm:w-auto">
          Pedir presupuesto
        </a>
        <a href={siteConfig.whatsapp} target="_blank" rel="noopener" class="inline-block w-full border border-white/70 text-center text-white text-xs uppercase px-10 py-4 hover:bg-white hover:text-[#201400] transition-all duration-300 sm:w-auto">
          WhatsApp
        </a>
      </div>
    </div>
  </section>
</Layout>
