const decoracionScrollSteps = [
  {
    image: '/images/Decoracion-1.webp',
    alt: 'Dormitorio cálido con cabecero de fibras naturales y aplique decorativo',
    label: 'Paleta y equilibrio',
    title: 'Decoración de interiores',
    body: 'Creamos ambientes armoniosos eligiendo cuidadosamente la paleta de colores, el mobiliario, los textiles y los elementos decorativos. Proponemos la distribución ideal del espacio para lograr equilibrio visual, comodidad y personalidad.',
    note: 'Ideal para quienes desean renovar sin hacer reformas.',
  },
  {
    image: '/images/service-decoracion-bedroom.webp',
    alt: 'Dormitorio contemporáneo con iluminación indirecta y tonos neutros',
    label: 'Luz y descanso',
    title: 'Atmósferas serenas',
    body: 'Trabajamos la luz, las proporciones y los materiales para que cada estancia resulte acogedora, coherente y fácil de vivir.',
    note: 'Una intervención decorativa puede cambiar por completo la percepción del espacio.',
  },
  {
    image: '/images/service-decoracion-textures.webp',
    alt: 'Dormitorio con fibras naturales, lámpara artesanal y textura mediterránea',
    label: 'Texturas naturales',
    title: 'Detalles que dan carácter',
    body: 'Seleccionamos piezas, tejidos y acabados que suman calidez sin saturar, manteniendo una estética natural y personalizada.',
    note: 'El objetivo es que el espacio se sienta tuyo desde el primer día.',
    cta: true,
  },
];

const interiorismoScrollSteps = [
  {
    image: '/images/service-interiorismo-comedor.webp',
    alt: 'Comedor con mesa de madera natural, cerámica artesanal y cocina al fondo',
    label: 'Proyecto integral',
    title: 'Proyectos de interiorismo',
    body: 'Ofrecemos un servicio integral de interiorismo personalizado en Almería. Realizamos un estudio completo del espacio y desarrollamos un proyecto técnico y estético que incluye:',
    bullets: [
      'Planos de zonificación y distribución',
      'Selección de materiales y revestimiento',
      'Soluciones funcionales y sostenibles',
    ],
    note: 'Perfecto para reformas completas o nuevas viviendas.',
  },
  {
    image: '/images/service-interiorismo-detalle.webp',
    alt: 'Detalle de plantas, cerámica y textura mural en tonos tierra',
    label: 'Materiales',
    title: 'Decisiones con criterio',
    body: 'La selección de materiales, revestimientos y acabados define la personalidad del proyecto. Buscamos coherencia visual, durabilidad y una sensación natural en cada espacio.',
    note: 'Cada elección responde a una intención estética y funcional.',
  },
  {
    image: '/images/service-interiorismo-recibidor.webp',
    alt: 'Recibidor mediterráneo con banco de fibras naturales, espejo y luz suave',
    label: 'Distribución',
    title: 'Espacios que funcionan',
    body: 'Analizamos recorridos, usos y proporciones para que la vivienda sea cómoda, fluida y equilibrada. El proyecto une la parte técnica con una experiencia diaria más sencilla.',
    note: 'Interiorismo pensado para vivir mejor, no solo para verse bien.',
    cta: true,
  },
];

const cocinasScrollSteps = [
  {
    image: '/images/service-cocinas-natural.webp',
    alt: 'Cocina luminosa con madera clara, baldas abiertas y vajilla artesanal',
    label: 'A medida',
    title: 'Diseño de cocinas & baños a medida',
    body: 'Diseñamos cocinas y baños en Almería, adaptados a tus gustos, hábitos y necesidades.',
    extraBody: 'Nuestro enfoque combina estética, ergonomía y aprovechamiento del espacio para que estas áreas clave del hogar sean funcionales y agradables.',
    note: 'Soluciones a medida con atención al detalle.',
  },
  {
    image: '/images/service-cocinas-dekton.webp',
    alt: 'Cocina contemporánea con encimera y revestimiento pétreo, madera y luz indirecta',
    label: 'Materiales técnicos',
    title: 'Belleza y resistencia',
    body: 'La elección de encimeras, frentes, iluminación y almacenaje define una cocina que debe responder al uso diario sin perder presencia estética.',
    note: 'Pensamos cada material desde su función, durabilidad y sensación visual.',
  },
  {
    image: '/images/service-cocinas-detalle.webp',
    alt: 'Detalle de cocina en madera con cajón abierto, cerámica y superficie pétrea',
    label: 'Detalle funcional',
    title: 'Orden que se nota',
    body: 'Trabajamos el interior del mobiliario, los recorridos y los pequeños gestos para que cocinar, guardar y limpiar resulte más cómodo.',
    note: 'La diferencia está en los detalles que simplifican el día a día.',
    cta: true,
  },
];

const serviceScrollStories = [
  {
    eyebrow: 'Nuestros servicios',
    title: 'Decoración de interiores',
    href: '/servicios#servicio-1',
    steps: decoracionScrollSteps,
  },
  {
    eyebrow: 'Nuestros servicios',
    title: 'Proyectos de interiorismo',
    href: '/servicios#servicio-2',
    steps: interiorismoScrollSteps,
  },
  {
    eyebrow: 'Nuestros servicios',
    title: 'Diseño de cocinas & baños a medida',
    href: '/servicios#servicio-3',
    steps: cocinasScrollSteps,
  },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      "@id": `${siteConfig.url}/#website`,
      "url": siteConfig.url,
      "name": "MHK Studio",
      "description": siteConfig.description,
      "inLanguage": "es"
    },
    {
      "@type": "WebPage",
      "@id": `${siteConfig.url}/#webpage`,
      "url": siteConfig.url,
      "name": "MHK Studio | Diseño de interiores en Mojácar",
      "isPartOf": { "@id": `${siteConfig.url}/#website` },
      "inLanguage": "es"
    }
  ]
};
---

<Layout
  title="Diseño de interiores en Mojácar | MHK Studio Interiorismo"
  description={siteConfig.description}
  canonical={siteConfig.url}
  schema={schema}
  noHeaderOffset={true}
>
  <!-- HERO -->
  <section class="relative flex min-h-[620px] h-screen items-center justify-center overflow-hidden">
    <div class="home-hero-carousel absolute inset-0" aria-hidden="true">
      {heroSlides.map((src, index) => (
        <img
          src={src}
          alt=""
          class="home-hero-slide"
          loading="eager"
          style={`--slide-delay: ${index * 3}s;`}
        />
      ))}
      <div class="absolute inset-0 bg-[#fdfaf7]/10"></div>
    </div>
    <div class="relative z-10 flex w-full flex-col items-center justify-center px-8 pt-16 lg:pt-24">
      <img
        src="/images/MHK.webp"
        alt="MHK"
        class="home-hero-logo"
        loading="eager"
      />
      <p class="home-hero-subtitle mt-6 text-center text-xs uppercase tracking-[0.55em] text-[#201400] sm:text-sm">
        Interior Design Studio
      </p>
    </div>
  </section>

  <!-- INTRO -->
  <section class="bg-white px-6 py-20 md:py-24">
    <div class="mx-auto grid max-w-6xl grid-cols-1 gap-12 md:grid-cols-[0.85fr_1.65fr] md:items-center md:gap-16">
      <div>
        <img
          src="/images/icono-comillas.webp"
          alt=""
          class="mb-8 h-14 w-auto"
          loading="lazy"
        />
        <p class="text-4xl font-medium uppercase leading-tight text-[#020202] md:text-5xl">
          Designing<br />
          <span class="font-light">for</span> Living
        </p>
      </div>
      <div>
        <div class="space-y-7">
          <div>
            <h2 class="mb-8 text-xl font-medium leading-snug text-[#bda589] md:text-2xl">
              Diseño de interiores personalizado que transforma tu hogar y tu bienestar
            </h2>
            <div class="max-w-3xl space-y-6 text-lg leading-relaxed text-[#020202]">
              <p>
                En MHK Studio somos un estudio de diseño de interiores en Almería apasionado por crear espacios únicos, funcionales y con alma. Diseñamos ambientes que reflejan la personalidad, el estilo de vida y las emociones de cada cliente, cuidando cada detalle del proceso creativo y técnico.
              </p>
              <p>
                Creemos que el diseño de interiores va más allá de lo estético: transforma la forma en que vivimos, sentimos y nos relacionamos con el espacio. Por eso, nuestro enfoque se centra en comprender a fondo tus necesidades, tu sensibilidad y tus objetivos, para ofrecerte soluciones a medida que potencien tu bienestar.
              </p>
            </div>
          </div>

          <div class="border-t border-[#bda589]/35 pt-7">
            <h3 class="mb-5 text-xl font-medium leading-snug text-[#bda589] md:text-2xl">
              Diseñamos interiores que equilibran estética, bienestar y vida cotidiana.
            </h3>
            <p class="max-w-3xl text-lg leading-relaxed text-[#020202]">
              Cada proyecto parte de una escucha real: cómo vives, qué necesitas y qué quieres sentir en casa.
            </p>
          </div>
        </div>
        <a
          href="/sobre-nosotros"
          class="mt-9 inline-block w-full max-w-2xl rounded-[8px] bg-[#bda589] px-8 py-4 text-center text-sm uppercase tracking-[0.14em] text-[#020202] transition-colors duration-300 hover:bg-[#9a7d62]"
        >
          Conocer más
        </a>
      </div>
    </div>
  </section>

  <!-- EDITORIAL CAROUSEL -->
  <section class="py-16 px-6 bg-white overflow-hidden md:py-20">
    <div class="max-w-6xl mx-auto">
      <div class="grid grid-cols-1 gap-8 md:grid-cols-[0.8fr_1.2fr] md:items-end md:gap-12 mb-10">
        <div>
          <p class="text-xs uppercase text-[#bda589] mb-4">Inspiración mediterránea</p>
          <h2 class="text-3xl md:text-4xl font-light text-[#201400] leading-tight">
            Materiales, luz y calma como punto de partida
          </h2>
        </div>
        <p class="text-base text-[#201400]/65 leading-relaxed">
          Agua, olivo, espigas y sombras suaves construyen una paleta natural que conecta con la arquitectura y el paisaje de la zona. Una dirección visual serena para proyectos vividos, no decorados.
        </p>
      </div>
      <EditorialCarousel slides={editorialSlides} />
    </div>
  </section>

  <!-- SERVICES SCROLL STORY -->
  {serviceScrollStories.map((story, storyIndex) => (
    <section
      id={storyIndex === 0 ? 'servicios' : undefined}
      class={`service-scroll-section ${storyIndex % 2 === 0 ? 'bg-[#fdfaf7]' : 'bg-white'}`}
      data-scroll-service
      data-steps={story.steps.length}
    >
      <div class="service-scroll-sticky">
        <div class="service-scroll-inner mx-auto flex max-w-6xl flex-col justify-center px-6 py-8 md:py-10">
          <div class="mb-5 md:mb-6">
            <p class="mb-3 text-xs uppercase tracking-[0.4em] text-[#bda589]">{story.eyebrow}</p>
            <h2 class="text-3xl font-light text-[#201400] md:text-4xl">{story.title}</h2>
          </div>

          <div class="service-scroll-stage grid min-h-[440px] grid-cols-1 gap-8 md:grid-cols-[1.1fr_0.9fr] md:items-center md:gap-12">
            <div class="service-scroll-visual" aria-live="polite">
              {story.steps.map((step, index) => (
                <figure
                  class={`service-scroll-card ${index === 0 ? 'is-active' : ''}`}
                  data-service-panel={index}
                >
                  <img src={step.image} alt={step.alt} loading={index === 0 ? 'eager' : 'lazy'} />
                  <figcaption>{step.label}</figcaption>
                </figure>
              ))}
            </div>

            <div class="service-scroll-copy-wrap">
              <div class="mb-8 flex items-center gap-3">
                {story.steps.map((_, index) => (
                  <span
                    class={`service-scroll-dot ${index === 0 ? 'is-active' : ''}`}
                    data-service-dot={index}
                    aria-hidden="true"
                  ></span>
                ))}
              </div>

              {story.steps.map((step, index) => (
                <article
                  class={`service-scroll-copy ${index === 0 ? 'is-active' : ''}`}
                  data-service-copy={index}
                >
                  <p class="mb-5 text-sm uppercase tracking-[0.28em] text-[#bda589]">
                    {String(index + 1).padStart(2, '0')} / {step.label}
                  </p>
                  <h3 class="mb-6 text-3xl font-medium leading-tight text-[#201400] md:text-5xl">
                    {step.title}
                  </h3>
                  <p class="text-lg leading-relaxed text-[#201400]/80">
                    {step.body}
                  </p>
                  {'extraBody' in step && step.extraBody && (
                    <p class="mt-5 text-lg leading-relaxed text-[#201400]/80">
                      {step.extraBody}
                    </p>
                  )}
                  {'bullets' in step && step.bullets && (
                    <ul class="mt-5 space-y-2 text-lg leading-relaxed text-[#201400]/80">
                      {step.bullets.map((item) => (
                        <li class="flex gap-3">
                          <span class="mt-[0.62em] h-2 w-2 shrink-0 rounded-full bg-[#bda589]"></span>
                          <span>{item}</span>
                        </li>
                      ))}
                    </ul>
                  )}
                  <p class="mt-6 text-base italic leading-relaxed text-[#201400]">
                    {step.note}
                  </p>
                  {step.cta && (
                    <a
                      href={story.href}
                      class="mt-8 inline-block w-full max-w-md rounded-[8px] bg-[#bda589] px-8 py-4 text-center text-sm uppercase tracking-[0.14em] text-[#201400] transition-colors duration-300 hover:bg-[#9a7d62]"
                    >
                      Conocer más
                    </a>
                  )}
                </article>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>
  ))}

  <script>
    const serviceScrollSections = document.querySelectorAll('[data-scroll-service]');
    let serviceScrollTicking = false;

    const setServiceStep = (section, activeStep) => {
      section.querySelectorAll('[data-service-panel], [data-service-copy], [data-service-dot]').forEach((element) => {
        const elementStep =
          element.getAttribute('data-service-panel') ??
          element.getAttribute('data-service-copy') ??
          element.getAttribute('data-service-dot');

        element.classList.toggle('is-active', Number(elementStep) === activeStep);
      });
    };

    const updateServiceScroll = () => {
      serviceScrollSections.forEach((section) => {
        const steps = Number(section.getAttribute('data-steps') ?? 1);
        const rect = section.getBoundingClientRect();
        const scrollDistance = Math.max(section.clientHeight - window.innerHeight, 1);
        const progress = Math.min(Math.max(-rect.top / scrollDistance, 0), 0.999);
        const activeStep = Math.min(steps - 1, Math.floor(progress * steps));

        setServiceStep(section, activeStep);
      });

      serviceScrollTicking = false;
    };

    const requestServiceScrollUpdate = () => {
      if (serviceScrollTicking) return;
      serviceScrollTicking = true;
      window.requestAnimationFrame(updateServiceScroll);
    };

    updateServiceScroll();
    window.addEventListener('scroll', requestServiceScrollUpdate, { passive: true });
    window.addEventListener('resize', requestServiceScrollUpdate);
  </script>

  <!-- HOME STAGING -->
  <section class="bg-[#fdfaf7] px-6 py-16 md:py-20">
    <div class="mx-auto grid max-w-6xl grid-cols-1 gap-10 border-t border-[#bda589]/25 pt-12 md:grid-cols-[1.05fr_0.95fr] md:items-center md:gap-14">
      <figure class="order-2 overflow-hidden rounded-[8px] border border-[#bda589]/30 bg-white shadow-[0_24px_60px_rgba(32,20,0,0.08)] md:order-1">
        <img
          src="/images/Home-staging.webp"
          alt="Salón preparado para home staging con sofá, mesa auxiliar y decoración neutra"
          class="aspect-[4/3] h-full w-full object-cover"
          loading="lazy"
        />
      </figure>

      <div class="order-1 md:order-2">
        <p class="mb-5 text-xs uppercase tracking-[0.4em] text-[#bda589]">Servicio estratégico</p>
        <h2 class="mb-7 text-3xl font-light leading-tight text-[#201400] md:text-5xl">
          Home Staging profesional
        </h2>
        <p class="max-w-2xl text-lg leading-relaxed text-[#201400]/80">
          Optimizamos el aspecto de viviendas en venta o alquiler mediante técnicas de home staging en Almería.
          Revalorizamos el inmueble para mejorar su presentación visual y acelerar su comercialización.
        </p>

        <ul class="mt-7 space-y-3 text-lg leading-relaxed text-[#201400]/80">
          <li class="flex gap-3">
            <span class="mt-[0.62em] h-2 w-2 shrink-0 rounded-full bg-[#bda589]"></span>
            <span>Estilismo y orden visual</span>
          </li>
          <li class="flex gap-3">
            <span class="mt-[0.62em] h-2 w-2 shrink-0 rounded-full bg-[#bda589]"></span>
            <span>Soluciones de bajo coste y alto impacto</span>
          </li>
          <li class="flex gap-3">
            <span class="mt-[0.62em] h-2 w-2 shrink-0 rounded-full bg-[#bda589]"></span>
            <span>Fotografía atractiva</span>
          </li>
        </ul>

        <p class="mt-7 text-base italic leading-relaxed text-[#201400]">
          Especial para particulares, inmobiliarias y promotoras.
        </p>
        <a
          href="/servicios#servicio-4"
          class="mt-8 inline-block w-full max-w-md rounded-[8px] bg-[#bda589] px-8 py-4 text-center text-sm uppercase tracking-[0.14em] text-[#201400] transition-colors duration-300 hover:bg-[#9a7d62]"
        >
          Conocer más
        </a>
      </div>
    </div>
  </section>

  <!-- ONLINE ADVISORY -->
  <section class="bg-white px-6 py-16 md:py-20">
    <div class="mx-auto grid max-w-6xl grid-cols-1 gap-10 border-t border-[#bda589]/25 pt-12 md:grid-cols-[0.95fr_1.05fr] md:items-center md:gap-14">
      <h2 class="text-3xl font-light leading-tight text-[#201400] md:col-span-2 md:text-5xl">
        Asesoría online de decoración e interiorismo
      </h2>
      <div>
        <p class="mb-8 max-w-xl text-lg italic leading-relaxed text-[#201400]">
          Perfecto para quienes quieren empezar a renovar sin moverse de casa. Fácil, flexible y 100% adaptado a ti.
        </p>
        <div class="max-w-2xl space-y-5 text-base leading-relaxed text-[#201400]/75 md:text-lg">
          <p>
            Accede a nuestro conocimiento y estilo desde cualquier lugar. Te ofrecemos una sesión personalizada por videollamada en la que analizamos tus espacios, resolvemos dudas y te damos recomendaciones claras para transformar tu hogar.
          </p>
          <p>
            Ideal si buscas orientación profesional sin comprometerte a un proyecto completo.
          </p>
        </div>

        <div class="mt-9 grid gap-4">
          {[
            'Análisis de tus espacios con base en fotos y planos',
            'Sugerencias sobre distribución, colores, mobiliario y estilo',
            'Entrega de guía con ideas clave tras la sesión',
          ].map((item, index) => (
            <div class="flex items-start gap-4 border-t border-[#bda589]/25 pt-4">
              <span class="text-sm uppercase tracking-[0.18em] text-[#bda589]">
                {String(index + 1).padStart(2, '0')}
              </span>
              <p class="text-base leading-relaxed text-[#201400]">{item}</p>
            </div>
          ))}
        </div>

        <a
          href="/servicios#servicio-5"
          class="mt-10 inline-block w-full max-w-md rounded-[8px] bg-[#bda589] px-8 py-4 text-center text-sm uppercase tracking-[0.14em] text-[#201400] transition-colors duration-300 hover:bg-[#9a7d62]"
        >
          Conocer más
        </a>
      </div>

      <figure class="overflow-hidden rounded-[8px] border border-[#bda589]/30 bg-[#fdfaf7]">
        <img
          src="/images/Asesoramiento.webp"
          alt="Sesión de asesoría online de decoración con portátil, libreta y materiales de trabajo"
          class="aspect-[4/3] h-full w-full object-cover"
          loading="lazy"
        />
      </figure>
    </div>
  </section>

  <!-- BRANDS -->
  <section class="py-20 px-6 bg-white overflow-hidden">
    <div class="max-w-6xl mx-auto">
      <p class="text-center text-xs tracking-[0.4em] uppercase text-[#bda589] mb-12">Trabajamos con las mejores marcas</p>
      <div class="flex flex-wrap justify-center items-center gap-10 md:gap-14">
        {brandLogos.map(logo => (
          <img
            src={logo.src}
            alt={logo.name}
            class="h-10 w-auto object-contain grayscale hover:grayscale-0 transition-all duration-300 opacity-60 hover:opacity-100 md:h-12"
            loading="lazy"
          />
        ))}
      </div>
    </div>
  </section>

  <!-- TESTIMONIOS -->
  <section class="bg-white px-6 py-16">
    <div class="mx-auto max-w-7xl">
      <div class="relative" data-reviews-carousel>
        <div class="overflow-hidden px-1 py-2">
          <div class="flex gap-6 transition-transform duration-500 ease-out" data-reviews-track>
            {reviews.map((review) => (
              <article class="min-h-[230px] w-full shrink-0 basis-full rounded-[8px] bg-[#bda589] p-5 text-[#201400] shadow-[0_2px_8px_rgba(32,20,0,0.24)] sm:basis-[calc((100%_-_24px)/2)] lg:basis-[calc((100%_-_48px)/3)]">
                <div class="mb-4 flex items-start justify-between gap-4">
                  <div class="flex items-center gap-3">
                    <img
                      src={review.avatar}
                      alt={`Foto de perfil de ${review.name}`}
                      class="h-12 w-12 shrink-0 rounded-full border border-[#201400]/20 object-cover"
                      loading="lazy"
                    />
                    <div>
                      <p class="font-semibold leading-tight text-[#0057d8]">{review.name}</p>
                      <p class="mt-1 text-sm text-[#201400]/75">{review.time}</p>
                    </div>
                  </div>
                  <div class="font-semibold text-[#4285f4]" aria-label="Google">G</div>
                </div>
                <div class="mb-4 text-xl tracking-[0.05em] text-[#201400]" aria-label="5 estrellas">★★★★★</div>
                <p class="line-clamp-5 text-base leading-relaxed text-[#201400]">{review.text}</p>
              </article>
            ))}
          </div>
        </div>

        <button
          type="button"
          data-reviews-prev
          class="absolute left-0 top-1/2 grid h-10 w-10 -translate-x-1/2 -translate-y-1/2 place-items-center rounded-full border border-[#bda589]/45 bg-white text-xl text-[#201400] shadow-[0_4px_14px_rgba(32,20,0,0.18)] transition-colors hover:bg-[#bda589]"
          aria-label="Reseña anterior"
        >
          ‹
        </button>
        <button
          type="button"
          data-reviews-next
          class="absolute right-0 top-1/2 grid h-10 w-10 translate-x-1/2 -translate-y-1/2 place-items-center rounded-full border border-[#bda589]/45 bg-white text-xl text-[#201400] shadow-[0_4px_14px_rgba(32,20,0,0.18)] transition-colors hover:bg-[#bda589]"
          aria-label="Reseña siguiente"
        >
          ›
        </button>

        <div class="mt-5 flex justify-center gap-2" data-reviews-dots aria-label="Indicadores de reseñas"></div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-24 px-6 bg-[#bda589]">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="text-3xl md:text-4xl font-light text-white mb-6">
        ¿Quieres transformar tu espacio?
      </h2>
      <p class="text-white/85 mb-10 text-lg font-light leading-relaxed">
        Cuéntanos qué necesitas y te contactaremos en menos de 24h para agendar una asesoría personalizada.
      </p>
      <div class="flex flex-col items-center justify-center gap-3 sm:flex-row">
        <a
          href="/servicios#solicitar-asesoria"
          class="inline-block w-full bg-white text-center text-[#201400] text-xs uppercase px-10 py-4 hover:bg-[#201400] hover:text-white transition-all duration-300 sm:w-auto"
        >
          Solicitar Asesoría
        </a>
        <a
          href={siteConfig.whatsapp}
          target="_blank"
          rel="noopener"
          class="inline-block w-full border border-white/70 text-center text-white text-xs uppercase px-10 py-4 hover:bg-white hover:text-[#201400] transition-all duration-300 sm:w-auto"
        >
          Escribir por WhatsApp
        </a>
      </div>
    </div>
  </section>

  <script is:inline>
    (() => {
      const reviewsCarousel = document.querySelector('[data-reviews-carousel]');
      if (!reviewsCarousel) return;

      const track = reviewsCarousel.querySelector('[data-reviews-track]');
      const cards = Array.from(track?.children ?? []);
      const prevButton = reviewsCarousel.querySelector('[data-reviews-prev]');
      const nextButton = reviewsCarousel.querySelector('[data-reviews-next]');
      const dotsWrap = reviewsCarousel.querySelector('[data-reviews-dots]');
      let currentIndex = 0;
      let intervalId;

      const getPerView = () => {
        if (window.matchMedia('(min-width: 1024px)').matches) return 3;
        if (window.matchMedia('(min-width: 640px)').matches) return 2;
        return 1;
      };

      const getMaxIndex = () => Math.max(cards.length - getPerView(), 0);

      const renderDots = () => {
        if (!dotsWrap) return;
        dotsWrap.innerHTML = '';
        for (let index = 0; index <= getMaxIndex(); index += 1) {
          const dot = document.createElement('button');
          dot.type = 'button';
          dot.className = 'h-2 w-2 rounded-full bg-[#bda589]/45 transition-all data-[active=true]:w-6 data-[active=true]:bg-[#bda589]';
          dot.setAttribute('aria-label', `Ver grupo de reseñas ${index + 1}`);
          dot.addEventListener('click', () => {
            currentIndex = index;
            updateCarousel();
            restartAutoplay();
          });
          dotsWrap.append(dot);
        }
      };

      const updateCarousel = () => {
        if (!track || cards.length === 0) return;
        currentIndex = Math.min(currentIndex, getMaxIndex());
        const card = cards[0];
        const cardWidth = card.getBoundingClientRect().width;
        const gap = Number.parseFloat(window.getComputedStyle(track).columnGap) || 0;
        track.style.transform = `translateX(-${currentIndex * (cardWidth + gap)}px)`;
        dotsWrap?.querySelectorAll('button').forEach((dot, index) => {
          dot.dataset.active = String(index === currentIndex);
        });
      };

      const goToNext = () => {
        currentIndex = currentIndex >= getMaxIndex() ? 0 : currentIndex + 1;
        updateCarousel();
      };

      const goToPrev = () => {
        currentIndex = currentIndex <= 0 ? getMaxIndex() : currentIndex - 1;
        updateCarousel();
      };

      const restartAutoplay = () => {
        window.clearInterval(intervalId);
        intervalId = window.setInterval(goToNext, 5000);
      };

      prevButton?.addEventListener('click', () => {
        goToPrev();
        restartAutoplay();
      });
      nextButton?.addEventListener('click', () => {
        goToNext();
        restartAutoplay();
      });
      window.addEventListener('resize', () => {
        renderDots();
        updateCarousel();
      });

      renderDots();
      updateCarousel();
      restartAutoplay();
    })();
  </script>
</Layout>
