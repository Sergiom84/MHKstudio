---
import Layout from '../layouts/Layout.astro';
import EditorialCarousel from '../components/EditorialCarousel.astro';
import { services, brandLogos, siteConfig, locations, editorialSlides } from '../data/locations';

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      "@id": `${siteConfig.url}/#website`,
      "url": siteConfig.url,
      "name": "MHK Studio",
      "description": siteConfig.description,
      "inLanguage": "es"
    },
    {
      "@type": "WebPage",
      "@id": `${siteConfig.url}/#webpage`,
      "url": siteConfig.url,
      "name": "MHK Studio | Diseño de interiores en Mojácar",
      "isPartOf": { "@id": `${siteConfig.url}/#website` },
      "inLanguage": "es"
    }
  ]
};
---

<Layout
  title="Diseño de interiores en Mojácar | MHK Studio Interiorismo"
  description={siteConfig.description}
  canonical={siteConfig.url}
  schema={schema}
>
  <!-- HERO -->
  <section class="relative min-h-screen flex items-center justify-center overflow-hidden">
    <div class="absolute inset-0">
      <img
        src="/images/PortadaInicio-1.webp"
        alt="Estudio de diseño de interiores MHK Studio"
        class="w-full h-full object-cover"
        loading="eager"
      />
      <div class="absolute inset-0 bg-[#201400]/40"></div>
    </div>
    <div class="relative z-10 text-center text-white px-6 max-w-4xl mx-auto">
      <p class="text-xs uppercase text-[#d4c0ab] mb-5">Designing for living</p>
      <h1 class="text-4xl md:text-6xl lg:text-7xl font-light italic mb-6 leading-tight">
        Interiorismo mediterráneo para hogares con alma
      </h1>
      <p class="text-lg md:text-xl font-light max-w-2xl mx-auto mb-10 leading-relaxed opacity-90">
        Diseñamos espacios personalizados, funcionales y serenos desde Mojácar para viviendas con luz, carácter y una forma de vivir propia.
      </p>
      <div class="flex flex-col items-center justify-center gap-3 sm:flex-row">
        <a
          href="/contacto"
          class="inline-block w-full border border-[#bda589] bg-[#bda589] px-8 py-4 text-center text-xs uppercase text-white transition-all duration-300 hover:border-white hover:bg-white hover:text-[#201400] sm:w-auto"
        >
          Hablemos de tu proyecto
        </a>
        <a
          href={siteConfig.whatsapp}
          target="_blank"
          rel="noopener"
          class="inline-block w-full border border-white/55 px-8 py-4 text-center text-xs uppercase text-white transition-all duration-300 hover:bg-white hover:text-[#201400] sm:w-auto"
        >
          WhatsApp
        </a>
      </div>
    </div>
    <!-- Scroll indicator -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2">
      <div class="w-px h-12 bg-white/40"></div>
    </div>
  </section>

  <!-- INTRO -->
  <section class="py-24 px-6 bg-[#fdfaf7]">
    <div class="max-w-4xl mx-auto text-center">
      <p class="text-xs tracking-[0.4em] uppercase text-[#bda589] mb-6">Estudio de Interiorismo</p>
      <h2 class="text-3xl md:text-4xl font-light text-[#201400] leading-relaxed mb-8">
        Diseñamos interiores que equilibran estética, bienestar y vida cotidiana.
      </h2>
      <p class="text-base text-[#201400]/70 leading-relaxed max-w-2xl mx-auto">
        Cada proyecto parte de una escucha real: cómo vives, qué necesitas y qué quieres sentir en casa. Con base en Mojácar (Almería), trabajamos en toda la provincia y en Murcia.
      </p>
    </div>
  </section>

  <!-- EDITORIAL CAROUSEL -->
  <section class="py-24 px-6 bg-white overflow-hidden">
    <div class="max-w-6xl mx-auto">
      <div class="grid grid-cols-1 gap-10 md:grid-cols-[0.8fr_1.2fr] md:items-end md:gap-16 mb-12">
        <div>
          <p class="text-xs uppercase text-[#bda589] mb-4">Inspiración mediterránea</p>
          <h2 class="text-3xl md:text-4xl font-light text-[#201400] leading-tight">
            Materiales, luz y calma como punto de partida
          </h2>
        </div>
        <p class="text-base text-[#201400]/65 leading-relaxed">
          Agua, olivo, espigas y sombras suaves construyen una paleta natural que conecta con la arquitectura y el paisaje de la zona. Una dirección visual serena para proyectos vividos, no decorados.
        </p>
      </div>
      <EditorialCarousel slides={editorialSlides} />
    </div>
  </section>

  <!-- SERVICES -->
  <section class="py-24 px-6 bg-white" id="servicios">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-16">
        <p class="text-xs tracking-[0.4em] uppercase text-[#bda589] mb-4">Nuestros servicios</p>
        <h2 class="text-3xl md:text-4xl font-light text-[#201400]">¿En qué podemos ayudarte?</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-0">
        {services.map((service, i) => (
          <article class={`group relative overflow-hidden ${i === 4 ? 'md:col-span-2 lg:col-span-1' : ''}`}>
            <div class="aspect-[4/3] overflow-hidden">
              <img
                src={service.image}
                alt={service.alt}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
                loading="lazy"
              />
            </div>
            <div class="p-8 bg-[#fdfaf7]">
              <h3 class="text-lg font-light text-[#201400] mb-3">{service.title}</h3>
              <p class="text-sm text-[#201400]/65 leading-relaxed">{service.description}</p>
              <a href="/servicios" class="inline-block mt-5 text-xs tracking-[0.2em] uppercase text-[#bda589] hover:text-[#9a7d62] transition-colors">
                Saber más →
              </a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- PROCESO -->
  <section class="py-24 px-6 bg-[#fdfaf7]">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-16">
        <p class="text-xs tracking-[0.4em] uppercase text-[#bda589] mb-4">Cómo trabajamos</p>
        <h2 class="text-3xl md:text-4xl font-light text-[#201400]">Método de trabajo</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
        {[
          { num: '01', img: '/images/Encuentro.webp', title: 'Primer encuentro', desc: 'Analizamos tu espacio, necesidades y estilo de vida para entender tu visión.' },
          { num: '02', img: '/images/Planificacion.webp', title: 'Planificación', desc: 'Desarrollamos el proyecto técnico con planos, materiales y presupuesto detallado.' },
          { num: '03', img: '/images/Asesoramiento.webp', title: 'Asesoramiento', desc: 'Te guiamos en cada decisión: selección de mobiliario, materiales y acabados.' },
          { num: '04', img: '/images/Satisfaccion.webp', title: 'Satisfacción', desc: 'Entregamos el espacio transformado, cuidando cada detalle hasta el final.' },
        ].map(step => (
          <div class="text-center">
            <div class="aspect-square overflow-hidden rounded-full w-32 mx-auto mb-6">
              <img src={step.img} alt={step.title} class="w-full h-full object-cover" loading="lazy" />
            </div>
            <p class="text-3xl font-light text-[#bda589] mb-2">{step.num}</p>
            <h3 class="text-base font-medium text-[#201400] mb-3">{step.title}</h3>
            <p class="text-sm text-[#201400]/65 leading-relaxed">{step.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- BRANDS -->
  <section class="py-20 px-6 bg-white overflow-hidden">
    <div class="max-w-6xl mx-auto">
      <p class="text-center text-xs tracking-[0.4em] uppercase text-[#bda589] mb-12">Trabajamos con las mejores marcas</p>
      <div class="flex flex-wrap justify-center items-center gap-8 md:gap-12">
        {brandLogos.map(logo => (
          <img
            src={logo.src}
            alt={logo.name}
            class="h-8 w-auto object-contain grayscale hover:grayscale-0 transition-all duration-300 opacity-60 hover:opacity-100"
            loading="lazy"
          />
        ))}
      </div>
    </div>
  </section>

  <!-- TESTIMONIOS -->
  <section class="py-24 px-6 bg-[#201400] text-white">
    <div class="max-w-4xl mx-auto">
      <p class="text-center text-xs tracking-[0.4em] uppercase text-[#bda589] mb-12">Clientes</p>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        {[
          { name: 'Claudio P.', date: '28 Nov 2025', text: 'Excelente profesional. Nos ayudó a pensar y resolver dudas, aportando soluciones creativas. Muy recomendable.' },
          { name: 'Rafael A.', date: '18 Nov 2025', text: 'MHK Studio Design ha sido una ayuda incalculable. Profesional, cercana y con un gusto exquisito. Totalmente recomendable.' },
        ].map(review => (
          <div class="border border-[#bda589]/30 p-8">
            <img src="/images/icono-comillas.webp" alt="" class="h-6 mb-5 opacity-60" />
            <p class="text-sm text-white/80 leading-relaxed mb-6 italic">"{review.text}"</p>
            <div class="flex items-center justify-between">
              <p class="text-sm font-medium text-[#bda589]">{review.name}</p>
              <p class="text-xs text-white/40">{review.date}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-24 px-6 bg-[#bda589]">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="text-3xl md:text-4xl font-light text-white mb-6">
        ¿Quieres transformar tu espacio?
      </h2>
      <p class="text-white/85 mb-10 text-lg font-light leading-relaxed">
        Cuéntanos tu proyecto y te ayudamos a crear el hogar que siempre has imaginado.
      </p>
      <div class="flex flex-col items-center justify-center gap-3 sm:flex-row">
        <a
          href="/contacto"
          class="inline-block w-full bg-white text-center text-[#201400] text-xs uppercase px-10 py-4 hover:bg-[#201400] hover:text-white transition-all duration-300 sm:w-auto"
        >
          Contactar ahora
        </a>
        <a
          href={siteConfig.whatsapp}
          target="_blank"
          rel="noopener"
          class="inline-block w-full border border-white/70 text-center text-white text-xs uppercase px-10 py-4 hover:bg-white hover:text-[#201400] transition-all duration-300 sm:w-auto"
        >
          Escribir por WhatsApp
        </a>
      </div>
    </div>
  </section>

  <!-- DONDE TRABAJAMOS -->
  <section class="py-20 px-6 bg-[#fdfaf7]">
    <div class="max-w-6xl mx-auto text-center">
      <p class="text-xs tracking-[0.4em] uppercase text-[#bda589] mb-4">Área de trabajo</p>
      <h2 class="text-2xl md:text-3xl font-light text-[#201400] mb-10">Dónde trabajamos</h2>
      <div class="flex flex-wrap justify-center gap-3">
        {locations.map(loc => (
          <a
            href={`/${loc.slug}`}
            class="text-sm text-[#201400]/70 border border-[#bda589]/40 px-5 py-2 hover:bg-[#bda589] hover:text-white hover:border-[#bda589] transition-all duration-200"
          >
            {loc.city}
          </a>
        ))}
      </div>
    </div>
  </section>
</Layout>
