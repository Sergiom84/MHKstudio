---
import Layout from '../layouts/Layout.astro';
import { services, siteConfig } from '../data/locations';
---

<Layout
  title="Servicios de interiorismo y decoración"
  description="Descubre todos los servicios de MHK Studio: decoración de interiores, proyectos de interiorismo, diseño de cocinas y baños, home staging y asesoría online."
  canonical={`${siteConfig.url}/servicios`}
>
  <!-- Hero -->
  <section class="relative h-[60vh] min-h-[400px] flex items-end pb-16 overflow-hidden">
    <div class="absolute inset-0">
      <img src="/images/PortadaServicios.webp" alt="Servicios de interiorismo MHK Studio" class="w-full h-full object-cover" loading="eager" />
      <div class="absolute inset-0 bg-[#201400]/50"></div>
    </div>
    <div class="relative z-10 max-w-6xl mx-auto px-6 w-full">
      <p class="text-xs tracking-[0.4em] uppercase text-[#bda589] mb-3">MHK Studio</p>
      <h1 class="text-4xl md:text-5xl font-light text-white leading-tight">
        Servicios de interiorismo<br />y decoración
      </h1>
    </div>
  </section>

  <!-- Intro -->
  <section class="py-20 px-6 bg-[#fdfaf7]">
    <div class="max-w-3xl mx-auto text-center">
      <p class="text-base text-[#201400]/70 leading-relaxed">
        En MHK Studio transformamos espacios cotidianos en ambientes únicos, acogedores y llenos de estilo. Cada proyecto es un proceso de escucha, diseño y ejecución personalizado para cada cliente.
      </p>
    </div>
  </section>

  <!-- Services detail -->
  {services.map((service, i) => (
    <section class={`py-20 px-6 ${i % 2 === 0 ? 'bg-white' : 'bg-[#fdfaf7]'}`}>
      <div class="max-w-6xl mx-auto">
        <div class={`grid grid-cols-1 md:grid-cols-2 gap-12 items-center ${i % 2 !== 0 ? 'md:[&>*:first-child]:order-2' : ''}`}>
          <div class="overflow-hidden">
            <img src={service.image} alt={service.alt} class="w-full aspect-[4/3] object-cover" loading="lazy" />
          </div>
          <div>
            <p class="text-xs tracking-[0.4em] uppercase text-[#bda589] mb-4">Servicio {String(i + 1).padStart(2, '0')}</p>
            <h2 class="text-2xl md:text-3xl font-light text-[#201400] mb-6 leading-snug">{service.title}</h2>
            <p class="text-base text-[#201400]/65 leading-relaxed mb-8">{service.description}</p>
            <a
              href="/contacto"
              class="inline-block border border-[#bda589] text-[#bda589] text-xs tracking-[0.3em] uppercase px-8 py-3 hover:bg-[#bda589] hover:text-white transition-all duration-300"
            >
              Solicitar información
            </a>
          </div>
        </div>
      </div>
    </section>
  ))}

  <!-- CTA -->
  <section class="py-24 px-6 bg-[#bda589]">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="text-3xl font-light text-white mb-6">¿Hablamos de tu proyecto?</h2>
      <p class="text-white/85 mb-10 font-light leading-relaxed">
        Cuéntanos qué tienes en mente y encontraremos el servicio ideal para ti.
      </p>
      <div class="flex flex-col items-center justify-center gap-3 sm:flex-row">
        <a href="/contacto" class="inline-block w-full bg-white text-center text-[#201400] text-xs uppercase px-10 py-4 hover:bg-[#201400] hover:text-white transition-all duration-300 sm:w-auto">
          Contactar
        </a>
        <a href={siteConfig.whatsapp} target="_blank" rel="noopener" class="inline-block w-full border border-white/70 text-center text-white text-xs uppercase px-10 py-4 hover:bg-white hover:text-[#201400] transition-all duration-300 sm:w-auto">
          WhatsApp
        </a>
      </div>
    </div>
  </section>
</Layout>
