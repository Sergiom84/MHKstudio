---
import { siteConfig, locations } from '../data/locations';
import { getRoutePath, getLocationPath, type Lang } from '../i18n/routes';
import { ui } from '../i18n/content';

interface Props {
  lang?: Lang;
}

const { lang = 'es' } = Astro.props;
const copy = ui[lang];

const socialLinks = [
  {
    label: 'WhatsApp',
    href: siteConfig.whatsapp,
    icon: '<path d="M12.04 2a9.86 9.86 0 0 0-8.47 14.9L2.5 22l5.23-1.37A9.96 9.96 0 1 0 12.04 2Zm.01 1.8a8.15 8.15 0 0 1 6.9 12.5 8.17 8.17 0 0 1-10.75 2.5l-.37-.2-3.1.82.82-3.02-.23-.39A8.07 8.07 0 0 1 3.9 12a8.16 8.16 0 0 1 8.15-8.2Zm-3.3 4.3c-.18 0-.47.07-.72.34-.25.28-.95.93-.95 2.26 0 1.34.98 2.63 1.12 2.82.14.18 1.9 3.04 4.7 4.14 2.33.92 2.8.74 3.31.69.5-.05 1.64-.67 1.87-1.32.23-.65.23-1.2.16-1.32-.07-.12-.25-.18-.53-.32-.28-.14-1.64-.81-1.9-.9-.25-.1-.44-.14-.62.14-.18.27-.72.9-.88 1.08-.16.18-.32.2-.6.07-.28-.14-1.17-.43-2.23-1.38-.82-.74-1.38-1.65-1.54-1.93-.16-.28-.02-.43.12-.57.12-.12.28-.32.42-.48.14-.16.18-.28.28-.46.09-.18.04-.34-.02-.48-.07-.14-.62-1.5-.85-2.05-.22-.53-.45-.46-.62-.47h-.52Z" />',
  },
  {
    label: 'Instagram',
    href: siteConfig.instagram,
    icon: '<rect x="4" y="4" width="16" height="16" rx="5" ry="5"></rect><path d="M16.2 11.37a4.2 4.2 0 1 1-8.4 0 4.2 4.2 0 0 1 8.4 0Z"></path><path d="M17.5 6.5h.01"></path>',
  },
  {
    label: 'Facebook',
    href: siteConfig.facebook,
    icon: '<path d="M14 8h2.2V4.4A24.8 24.8 0 0 0 13 4c-3.16 0-5.32 1.93-5.32 5.45V12H4.2v4h3.48v8h4.26v-8h3.34l.53-4h-3.87V9.85C11.94 8.7 12.25 8 14 8Z" />',
  },
  {
    label: 'Pinterest',
    href: siteConfig.pinterest,
    icon: '<path d="M12.04 2.5a9.5 9.5 0 0 0-3.46 18.35c-.08-.79-.16-2 .03-2.86l1.1-4.67s-.28-.57-.28-1.4c0-1.32.76-2.3 1.7-2.3.8 0 1.2.6 1.2 1.33 0 .81-.52 2.03-.79 3.16-.22.94.47 1.7 1.4 1.7 1.68 0 2.98-1.78 2.98-4.34 0-2.27-1.63-3.86-3.96-3.86-2.7 0-4.29 2.02-4.29 4.12 0 .81.31 1.68.7 2.15.08.1.09.18.07.28l-.26 1.06c-.04.17-.14.2-.32.12-1.2-.56-1.95-2.32-1.95-3.74 0-3.04 2.2-5.82 6.35-5.82 3.34 0 5.93 2.38 5.93 5.55 0 3.32-2.1 5.99-5 5.99-.98 0-1.9-.5-2.2-1.1l-.6 2.29c-.22.86-.81 1.93-1.2 2.58A9.5 9.5 0 1 0 12.04 2.5Z" />',
  },
];
---

<footer class="bg-[#201400] text-[#fdfaf7] pt-16 pb-8 mt-0">
  <div class="max-w-6xl mx-auto px-6">
    <!-- Top grid -->
    <div class="grid grid-cols-1 gap-10 mb-12 md:grid-cols-5">

      <!-- Brand -->
      <div class="md:col-span-1">
        <img src="/images/MHK-interior-design-studio.webp" alt="MHK Studio" class="h-10 w-auto mb-4 brightness-0 invert" />
        <p class="text-xs tracking-[0.3em] uppercase text-[#bda589] mb-5">designing for living</p>
        <p class="text-sm text-[#fdfaf7]/80">{copy.footer.socialFollow}</p>
        <div class="mt-4 flex items-center gap-4">
          {socialLinks.map((link) => (
            <a
              href={link.href}
              target="_blank"
              rel="noopener"
              aria-label={link.label}
              title={link.label}
              class="grid h-8 w-8 place-items-center text-[#bda589]/85 transition-colors hover:text-[#fdfaf7]"
            >
              <svg
                viewBox="0 0 24 24"
                aria-hidden="true"
                class="h-5 w-5"
                fill={link.label === 'Instagram' ? 'none' : 'currentColor'}
                stroke={link.label === 'Instagram' ? 'currentColor' : 'none'}
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                set:html={link.icon}
              />
            </a>
          ))}
        </div>
      </div>

      <!-- Recursos -->
      <div>
        <h3 class="text-xs font-medium tracking-[0.3em] uppercase text-[#bda589] mb-4">{copy.footer.resources}</h3>
        <ul class="space-y-2">
          <li><a href="/aviso-legal" class="text-sm text-[#fdfaf7]/70 hover:text-[#fdfaf7] transition-colors">{copy.footer.legal}</a></li>
          <li><a href="/politica-de-privacidad" class="text-sm text-[#fdfaf7]/70 hover:text-[#fdfaf7] transition-colors">{copy.footer.privacy}</a></li>
          <li><a href="/politica-de-cookies" class="text-sm text-[#fdfaf7]/70 hover:text-[#fdfaf7] transition-colors">{copy.footer.cookies}</a></li>
          <li><a href="/condiciones-generales" class="text-sm text-[#fdfaf7]/70 hover:text-[#fdfaf7] transition-colors">{copy.footer.terms}</a></li>
        </ul>
      </div>

      <!-- MHK Studio links -->
      <div>
        <h3 class="text-xs font-medium tracking-[0.3em] uppercase text-[#bda589] mb-4">MHKstudio.design</h3>
        <ul class="space-y-2">
          <li><a href={getRoutePath('about', lang)} class="text-sm text-[#fdfaf7]/70 hover:text-[#fdfaf7] transition-colors">{copy.nav.about}</a></li>
          <li><a href={getRoutePath('services', lang)} class="text-sm text-[#fdfaf7]/70 hover:text-[#fdfaf7] transition-colors">{copy.nav.services}</a></li>
          <li><a href={getRoutePath('contact', lang)} class="text-sm text-[#fdfaf7]/70 hover:text-[#fdfaf7] transition-colors">{copy.footer.contact}</a></li>
        </ul>
      </div>

      <!-- Dónde trabajamos -->
      <div>
        <h3 class="text-xs font-medium tracking-[0.3em] uppercase text-[#bda589] mb-4">{copy.footer.where}</h3>
        <ul class="space-y-2 columns-2">
          {locations.map(loc => (
            <li>
              <a href={getLocationPath(loc.slug, lang)} class="text-sm text-[#fdfaf7]/70 hover:text-[#fdfaf7] transition-colors">
                {loc.city}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contacto -->
      <div>
        <h3 class="text-xs font-medium tracking-[0.3em] uppercase text-[#bda589] mb-4">{copy.footer.contact}</h3>
        <ul class="space-y-3">
          <li>
            <p class="text-xs text-[#bda589]/60 uppercase tracking-wider mb-1">{copy.footer.phone}</p>
            <a href={siteConfig.phoneHref} class="text-sm text-[#fdfaf7]/80 hover:text-[#fdfaf7] transition-colors">{siteConfig.phone}</a>
          </li>
          <li>
            <p class="text-xs text-[#bda589]/60 uppercase tracking-wider mb-1">{copy.footer.email}</p>
            <a href={`mailto:${siteConfig.email}`} class="text-sm text-[#fdfaf7]/80 hover:text-[#fdfaf7] transition-colors">{siteConfig.email}</a>
          </li>
          <li>
            <p class="text-xs text-[#bda589]/60 uppercase tracking-wider mb-1">{copy.footer.address}</p>
            <p class="text-sm text-[#fdfaf7]/80">{siteConfig.address}</p>
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="border-t border-[#bda589]/20 pt-6 flex flex-col md:flex-row justify-between items-center gap-4">
      <p class="text-xs text-[#fdfaf7]/40">© {new Date().getFullYear()} MHK Studio · {copy.footer.rights}</p>
    </div>
  </div>
</footer>
