---
import type { EditorialSlide } from '../data/locations';

interface Props {
  slides: EditorialSlide[];
}

const { slides } = Astro.props;
---

<div class="relative">
  <div
    class="grid grid-cols-1 gap-4 md:gap-6 lg:grid-cols-3"
    aria-label="Inspiración visual de MHK Studio"
  >
    {slides.map((slide) => (
      <article
        class="group relative overflow-hidden bg-[#fdfaf7]"
      >
        <div class="aspect-[3/4] overflow-hidden">
          <picture>
            <source srcset={slide.avifSrc} type="image/avif" />
            <img
              src={slide.src}
              alt={slide.alt}
              class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-[1.03]"
              loading="lazy"
            />
          </picture>
        </div>
        <div class="absolute inset-x-0 bottom-0 bg-gradient-to-t from-[#201400]/80 via-[#201400]/35 to-transparent p-5 text-white">
          <p class="mb-2 text-xs uppercase text-[#d4c0ab]">{slide.category}</p>
          <p class="max-w-xs text-sm leading-relaxed text-white/90">{slide.caption}</p>
        </div>
      </article>
    ))}
  </div>
</div>
