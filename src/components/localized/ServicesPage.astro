---
import Layout from '../../layouts/Layout.astro';
import ReviewsCarousel from './ReviewsCarousel.astro';
import { siteConfig } from '../../data/locations';
import { servicesContent, serviceImages, ui } from '../../i18n/content';
import { absoluteUrl, getRoutePath, type Lang } from '../../i18n/routes';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const copy = ui[lang];
const content = servicesContent[lang];
const canonicalPath = getRoutePath('services', lang);
const canonical = absoluteUrl(siteConfig.url, canonicalPath);
const introParts = content.intro.split('MHK Studio');

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": `${canonical}#webpage`,
      "url": canonical,
      "name": content.title,
      "description": content.description,
      "isPartOf": { "@id": `${siteConfig.url}/#website` },
      "about": { "@id": `${siteConfig.url}/#organization` },
      "inLanguage": lang
    },
    {
      "@type": "BreadcrumbList",
      "@id": `${canonical}#breadcrumb`,
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": copy.nav.home, "item": absoluteUrl(siteConfig.url, getRoutePath('home', lang)) },
        { "@type": "ListItem", "position": 2, "name": copy.nav.services, "item": canonical }
      ]
    },
    {
      "@type": "ItemList",
      "@id": `${canonical}#services`,
      "name": content.title,
      "itemListElement": content.details.map((service, index) => ({
        "@type": "ListItem",
        "position": index + 1,
        "item": {
          "@type": "Service",
          "name": service.title,
          "description": service.paragraphs.flat().map((part) => part.text).join(" "),
          "provider": { "@id": `${siteConfig.url}/#organization` },
          "areaServed": "Almería"
        }
      }))
    }
  ]
};
---

<Layout title={content.title} description={content.description} canonical={canonical} schema={schema} lang={lang} noHeaderOffset={true}>
  <section class="services-hero relative flex min-h-[58vh] items-center justify-center overflow-hidden bg-[#d4c0ab] px-6 py-20 text-center md:min-h-[66vh]">
    <img
      src="/images/PortadaServicio.png"
      alt={content.hero}
      class="absolute inset-0 h-full w-full scale-[1.04] object-cover blur-[5px]"
      loading="eager"
    />
    <div class="absolute inset-0 bg-[#fdfaf7]/30"></div>
    <div class="relative z-10 mx-auto max-w-6xl">
      <h1 class="page-hero-title text-[#201400]">
        {content.hero}
      </h1>
    </div>
  </section>

  <section class="border-b border-[#bda589]/35 bg-white px-6 pb-16 pt-20 md:pt-24">
    <div class="mx-auto max-w-5xl text-center">
      <p class="mhk-body-reference text-[#201400]">
        {introParts.map((part, index) => (
          <>
            {index > 0 && <span class="text-[#b58f73]">MHK Studio</span>}
            {part}
          </>
        ))}
      </p>
    </div>
    <nav class="mx-auto mt-14 flex max-w-6xl flex-wrap justify-center gap-3" aria-label={content.navAria}>
      {content.details.map((service, index) => (
        <a
          href={`#servicio-${index + 1}`}
          class="rounded-full border border-[#bda589]/45 px-5 py-3 text-center text-xs uppercase tracking-[0.18em] text-[#201400] transition-colors hover:bg-[#bda589] hover:text-white"
        >
          {service.navTitle}
        </a>
      ))}
    </nav>
  </section>

  {content.details.map((service, index) => (
    <section
      id={`servicio-${index + 1}`}
      class={`relative overflow-hidden px-6 py-16 md:py-20 ${index % 2 === 0 ? 'bg-[#fdfaf7]' : 'bg-white'}`}
    >
      <div class={`mx-auto grid max-w-6xl grid-cols-1 gap-10 md:grid-cols-2 md:items-center md:gap-16 ${index % 2 === 1 ? 'md:[&>*:first-child]:order-2' : ''}`}>
        <figure class="relative">
          <img src="/images/Circulo.webp" alt="" class={`absolute ${index % 2 === 0 ? '-left-8 -top-8' : '-right-8 -top-8 rotate-45'} h-24 w-24 opacity-80`} aria-hidden="true" />
          <div class="relative overflow-hidden rounded-[28px] border border-[#bda589]/35 bg-[#d4c0ab] shadow-[0_24px_60px_rgba(32,20,0,0.10)]">
            <img src={serviceImages[index]} alt={service.title} class="aspect-[4/3] w-full object-cover" loading="lazy" />
          </div>
        </figure>

        <div>
          <h2 class="services-detail-heading mb-6 text-3xl font-light leading-tight text-[#201400] md:text-5xl">{service.title}</h2>
          <p class="mb-6 text-xs uppercase tracking-[0.32em] text-[#bda589]">{service.eyebrow}</p>
          {service.paragraphs.map((paragraph, paragraphIndex) => (
            <p class={`${paragraphIndex > 0 ? 'mt-5' : ''} mhk-body-reference text-[#201400]/80`}>
              {paragraph.map((part) => <span class={part.highlight ? 'text-[#b58f73]' : ''}>{part.text}</span>)}
            </p>
          ))}

          {service.bullets.length > 0 && (
            <ul class="mt-7 grid gap-3 text-base leading-relaxed text-[#201400]/75">
              {service.bullets.map((item) => (
                <li class="flex items-start gap-3">
                  <span class="mt-[0.58em] h-2 w-2 shrink-0 rounded-full bg-[#bda589]"></span>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          )}

          <p class="mt-8 border-l-2 border-[#bda589] pl-5 text-lg italic leading-relaxed text-[#9a7d62]">{service.note}</p>
        </div>
      </div>
    </section>
  ))}

  <ReviewsCarousel lang={lang} />

  <section id="solicitar-asesoria" class="bg-[#bda589] px-6 py-24">
    <div class="mx-auto max-w-3xl text-center">
      <h2 class="mb-6 text-3xl font-light text-white md:text-4xl">{content.ctaTitle}</h2>
      <p class="mhk-body-reference mb-10 text-white/85">{content.ctaBody}</p>
      <a href={siteConfig.whatsapp} target="_blank" rel="noopener" class="inline-block w-full border border-white/70 px-10 py-4 text-center text-xs uppercase text-white transition-all duration-300 hover:bg-white hover:text-[#201400] sm:w-auto">
        {copy.actions.whatsapp}
      </a>
      <div class="mt-8 w-full rounded-[8px] bg-[#fdfaf7] p-5 text-left text-[#201400] shadow-[0_18px_45px_rgba(32,20,0,0.14)] md:p-8">
        <p data-hubspot-loading class="text-sm leading-relaxed text-[#201400]/65">{content.loadingForm}</p>
        <div id="mhk-hubspot-asesoria-form" class="hbspt-form"></div>
      </div>
    </div>
  </section>

  <section class="relative h-20 overflow-hidden bg-[#201400]">
    <div class="absolute -right-16 top-12 opacity-20">
      <img src="/images/Circulo.webp" alt="" class="h-48 w-48 rotate-45" aria-hidden="true" />
    </div>
  </section>

  <script is:inline src="https://js.hsforms.net/forms/embed/v2.js"></script>
  <script is:inline>
    (() => {
      const formTarget = document.getElementById('mhk-hubspot-asesoria-form');
      const loadingMessage = document.querySelector('[data-hubspot-loading]');
      let formLoaded = false;

      const loadHubSpotForm = (attempt = 0) => {
        if (formLoaded || !formTarget) return;

        if (!window.hbspt?.forms) {
          if (attempt < 20) window.setTimeout(() => loadHubSpotForm(attempt + 1), 150);
          return;
        }

        formLoaded = true;
        loadingMessage?.remove();
        window.hbspt.forms.create({
          portalId: '49385837',
          formId: 'f07fd6a8-686f-4879-9230-7ba46a86744c',
          region: 'na1',
          target: '#mhk-hubspot-asesoria-form',
        });
      };

      loadHubSpotForm();
    })();
  </script>
</Layout>
