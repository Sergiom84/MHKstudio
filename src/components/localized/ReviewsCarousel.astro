---
import { getReviews, ui } from '../../i18n/content';
import type { Lang } from '../../i18n/routes';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const copy = ui[lang];
const reviews = getReviews(lang);
---

<section class="bg-white px-6 py-16">
  <div class="mx-auto max-w-7xl">
    <div class="relative" data-reviews-carousel>
      <div class="overflow-hidden px-1 py-2">
        <div class="flex gap-6 transition-transform duration-500 ease-out" data-reviews-track>
          {reviews.map((review) => (
            <article class="min-h-[230px] w-full shrink-0 basis-full rounded-[8px] bg-[#bda589] p-5 text-[#201400] shadow-[0_2px_8px_rgba(32,20,0,0.24)] sm:basis-[calc((100%_-_24px)/2)] lg:basis-[calc((100%_-_48px)/3)]">
              <div class="mb-4 flex items-start justify-between gap-4">
                <div class="flex items-center gap-3">
                  <img
                    src={review.avatar}
                    alt={review.name}
                    class="h-12 w-12 shrink-0 rounded-full border border-[#201400]/20 object-cover"
                    loading="lazy"
                  />
                  <div>
                    <p class="font-semibold leading-tight text-[#0057d8]">{review.name}</p>
                    <p class="mt-1 text-sm text-[#201400]/75">{review.time}</p>
                  </div>
                </div>
                <div class="font-semibold text-[#4285f4]" aria-label="Google">G</div>
              </div>
              <div class="mb-4 text-xl tracking-[0.05em] text-[#201400]" aria-label="5 stars">★★★★★</div>
              <p class="mhk-body-reference line-clamp-5 text-[#201400]">{review.text}</p>
            </article>
          ))}
        </div>
      </div>

      <button
        type="button"
        data-reviews-prev
        class="absolute left-0 top-1/2 grid h-10 w-10 -translate-x-1/2 -translate-y-1/2 place-items-center rounded-full border border-[#bda589]/45 bg-white text-xl text-[#201400] shadow-[0_4px_14px_rgba(32,20,0,0.18)] transition-colors hover:bg-[#bda589]"
        aria-label={copy.actions.previousReview}
      >
        ‹
      </button>
      <button
        type="button"
        data-reviews-next
        class="absolute right-0 top-1/2 grid h-10 w-10 translate-x-1/2 -translate-y-1/2 place-items-center rounded-full border border-[#bda589]/45 bg-white text-xl text-[#201400] shadow-[0_4px_14px_rgba(32,20,0,0.18)] transition-colors hover:bg-[#bda589]"
        aria-label={copy.actions.nextReview}
      >
        ›
      </button>

      <div
        class="mt-5 flex justify-center gap-2"
        data-reviews-dots
        aria-label={copy.actions.reviewGroup}
        data-review-group-label={copy.actions.reviewGroup}
      ></div>
    </div>
  </div>
</section>

<script is:inline>
  (() => {
    const reviewsCarousel = document.querySelector('[data-reviews-carousel]');
    if (!reviewsCarousel) return;

    const track = reviewsCarousel.querySelector('[data-reviews-track]');
    const cards = Array.from(track?.children ?? []);
    const prevButton = reviewsCarousel.querySelector('[data-reviews-prev]');
    const nextButton = reviewsCarousel.querySelector('[data-reviews-next]');
    const dotsWrap = reviewsCarousel.querySelector('[data-reviews-dots]');
    let currentIndex = 0;
    let intervalId;

    const getPerView = () => {
      if (window.matchMedia('(min-width: 1024px)').matches) return 3;
      if (window.matchMedia('(min-width: 640px)').matches) return 2;
      return 1;
    };

    const getMaxIndex = () => Math.max(cards.length - getPerView(), 0);

    const renderDots = () => {
      if (!dotsWrap) return;
      dotsWrap.innerHTML = '';
      for (let index = 0; index <= getMaxIndex(); index += 1) {
        const dot = document.createElement('button');
        dot.type = 'button';
        dot.className = 'h-2 w-2 rounded-full bg-[#bda589]/45 transition-all data-[active=true]:w-6 data-[active=true]:bg-[#bda589]';
        dot.setAttribute('aria-label', `${dotsWrap.dataset.reviewGroupLabel ?? 'Review group'} ${index + 1}`);
        dot.addEventListener('click', () => {
          currentIndex = index;
          updateCarousel();
          restartAutoplay();
        });
        dotsWrap.append(dot);
      }
    };

    const updateCarousel = () => {
      if (!track || cards.length === 0) return;
      currentIndex = Math.min(currentIndex, getMaxIndex());
      const card = cards[0];
      const cardWidth = card.getBoundingClientRect().width;
      const gap = Number.parseFloat(window.getComputedStyle(track).columnGap) || 0;
      track.style.transform = `translateX(-${currentIndex * (cardWidth + gap)}px)`;
      dotsWrap?.querySelectorAll('button').forEach((dot, index) => {
        dot.dataset.active = String(index === currentIndex);
      });
    };

    const goToNext = () => {
      currentIndex = currentIndex >= getMaxIndex() ? 0 : currentIndex + 1;
      updateCarousel();
    };

    const goToPrev = () => {
      currentIndex = currentIndex <= 0 ? getMaxIndex() : currentIndex - 1;
      updateCarousel();
    };

    const restartAutoplay = () => {
      window.clearInterval(intervalId);
      intervalId = window.setInterval(goToNext, 5000);
    };

    prevButton?.addEventListener('click', () => {
      goToPrev();
      restartAutoplay();
    });
    nextButton?.addEventListener('click', () => {
      goToNext();
      restartAutoplay();
    });
    window.addEventListener('resize', () => {
      renderDots();
      updateCarousel();
    });

    renderDots();
    updateCarousel();
    restartAutoplay();
  })();
</script>
