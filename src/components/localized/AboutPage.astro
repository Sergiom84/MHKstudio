---
import Layout from '../../layouts/Layout.astro';
import ReviewsCarousel from './ReviewsCarousel.astro';
import { siteConfig } from '../../data/locations';
import { aboutContent, methodImages, servicesContent, ui } from '../../i18n/content';
import { absoluteUrl, getRoutePath, type Lang } from '../../i18n/routes';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const copy = ui[lang];
const content = aboutContent[lang];
const servicesCopy = servicesContent[lang];
const canonicalPath = getRoutePath('about', lang);
const canonical = absoluteUrl(siteConfig.url, canonicalPath);

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "AboutPage",
      "@id": `${canonical}#webpage`,
      "url": canonical,
      "name": content.title,
      "description": content.description,
      "isPartOf": { "@id": `${siteConfig.url}/#website` },
      "about": { "@id": `${siteConfig.url}/#organization` },
      "inLanguage": lang
    },
    {
      "@type": "BreadcrumbList",
      "@id": `${canonical}#breadcrumb`,
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": copy.nav.home, "item": absoluteUrl(siteConfig.url, getRoutePath('home', lang)) },
        { "@type": "ListItem", "position": 2, "name": copy.nav.about, "item": canonical }
      ]
    }
  ]
};
---

<Layout title={content.title} description={content.description} canonical={canonical} schema={schema} lang={lang} noHeaderOffset={true}>
  <section class="relative flex min-h-[58vh] items-center justify-center overflow-hidden px-6 py-20 text-center md:min-h-[66vh]">
    <img
      src="/images/SobreNosotros.png"
      alt="MHK Studio interior design"
      class="absolute inset-0 h-full w-full scale-[1.04] object-cover blur-[5px]"
      loading="eager"
    />
    <div class="absolute inset-0 bg-[#fdfaf7]/30"></div>
    <div class="relative z-10 mx-auto max-w-6xl">
      <h1 class="page-hero-title text-[#120c00]" set:html={content.hero} />
    </div>
  </section>

  <section class="bg-white px-6 pb-24 pt-20 md:pt-24">
    <div class="mx-auto max-w-5xl">
      <div class="home-uniform-body mhk-body-reference mx-auto space-y-8 text-center text-[#201400]/80">
        {content.intro.map((paragraph) => <p set:html={paragraph} />)}
      </div>
      <div class="mt-24 h-px w-full bg-[#bda589]/65"></div>
    </div>
  </section>

  <section class="bg-white px-6 py-24">
    <div class="mx-auto max-w-[1430px] space-y-28">
      {content.values.map((item) => (
        <div class="grid grid-cols-1 gap-10 md:grid-cols-[0.82fr_1.18fr] md:gap-20">
          <div class="pt-2">
            <span class="mb-12 block h-8 w-8 rounded-full bg-[#bda589]"></span>
            <h2 class="whitespace-pre-line text-2xl font-light uppercase leading-snug tracking-[0.12em] text-[#020202]">
              {item.title}
            </h2>
          </div>
          <div class="home-uniform-body mhk-body-reference max-w-3xl space-y-8 text-justify text-[#201400]/80">
            {item.paragraphs.map((paragraph) => <p set:html={paragraph} />)}
          </div>
        </div>
      ))}
    </div>
  </section>

  <section class="bg-white px-6 py-24">
    <div class="mx-auto max-w-7xl">
      <div class="mb-24 h-px w-full bg-[#bda589]/65"></div>
      <div class="mb-20 text-center">
        <h2 class="text-4xl font-semibold uppercase tracking-[0.02em] text-[#020202] md:text-6xl">
          <span class="mhk-text-strong">Designing</span> <span class="font-light">for</span> <span class="mhk-text-strong">Living</span>
        </h2>
        <span class="mx-auto mb-24 mt-28 block h-8 w-8 rounded-full bg-[#bda589]"></span>
        <p class="home-intro-title-strong text-lg leading-snug text-[#bda589]">{content.methodTitle}</p>
      </div>

      <div class="grid grid-cols-1 gap-12 md:grid-cols-2 lg:grid-cols-4 lg:gap-16">
        {content.methodSteps.map((step, index) => (
          <article class="text-center">
            <img
              src={methodImages[index].image}
              alt={methodImages[index].alt}
              class="mb-8 aspect-square w-full rounded-[8px] object-cover shadow-[8px_8px_18px_rgba(32,20,0,0.18)]"
              loading="lazy"
            />
            <h3 class="mb-7 text-xl font-medium uppercase tracking-[0.04em] text-[#020202]">{step[0]}</h3>
            <p class="home-uniform-body mhk-body-reference mx-auto max-w-[260px] text-[#201400]/80">{step[1]}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <ReviewsCarousel lang={lang} />

  <section id="solicitar-asesoria" class="bg-[#bda589] px-6 py-24">
    <div class="mx-auto max-w-3xl text-center">
      <h2 class="mb-6 text-3xl font-light text-white md:text-4xl">{content.ctaTitle}</h2>
      <p class="mhk-body-reference mb-10 text-white/85">{content.ctaBody}</p>
      <a href={siteConfig.whatsapp} target="_blank" rel="noopener" class="inline-block w-full border border-white/70 px-10 py-4 text-center text-xs uppercase text-white transition-all duration-300 hover:bg-white hover:text-[#201400] sm:w-auto">
        {copy.actions.whatsapp}
      </a>
      <div class="mt-8 w-full rounded-[8px] bg-[#fdfaf7] p-5 text-left text-[#201400] shadow-[0_18px_45px_rgba(32,20,0,0.14)] md:p-8">
        <p data-hubspot-about-loading class="text-sm leading-relaxed text-[#201400]/65">{servicesCopy.loadingForm}</p>
        <div id="mhk-hubspot-about-form" class="hbspt-form"></div>
      </div>
    </div>
  </section>

  <script is:inline src="https://js.hsforms.net/forms/embed/v2.js"></script>
  <script is:inline>
    (() => {
      const formTarget = document.getElementById('mhk-hubspot-about-form');
      const loadingMessage = document.querySelector('[data-hubspot-about-loading]');
      let formLoaded = false;

      const loadHubSpotForm = (attempt = 0) => {
        if (formLoaded || !formTarget) return;

        if (!window.hbspt?.forms) {
          if (attempt < 20) window.setTimeout(() => loadHubSpotForm(attempt + 1), 150);
          return;
        }

        formLoaded = true;
        loadingMessage?.remove();
        window.hbspt.forms.create({
          portalId: '49385837',
          formId: 'f07fd6a8-686f-4879-9230-7ba46a86744c',
          region: 'na1',
          target: '#mhk-hubspot-about-form',
        });
      };

      loadHubSpotForm();
    })();
  </script>
</Layout>
