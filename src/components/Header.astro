---
import { siteConfig } from '../data/locations';

const navLinks = [
  { label: 'Servicios', href: '/servicios' },
  { label: 'Sobre nosotros', href: '/sobre-nosotros' },
  { label: 'Contáctanos', href: '/contacto' },
];
const currentPath = Astro.url.pathname;
---

<header class="fixed top-0 left-0 right-0 z-50 bg-[#fdfaf7]/95 backdrop-blur-sm border-b border-[#bda589]/20">
  <div class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">
    <a href="/" class="flex items-center">
      <img src="/images/MHK.webp" alt="MHK Studio" class="h-8 w-auto" loading="eager" />
    </a>

    <!-- Desktop Nav -->
    <nav class="hidden md:flex items-center gap-8">
      {navLinks.map(link => (
        <a
          href={link.href}
          class={`text-sm tracking-widest uppercase font-light transition-colors hover:text-[#bda589] ${currentPath.startsWith(link.href) ? 'text-[#bda589]' : 'text-[#201400]'}`}
        >
          {link.label}
        </a>
      ))}
      <a
        href={siteConfig.whatsapp}
        target="_blank"
        rel="noopener"
        class="border border-[#bda589]/60 px-4 py-2 text-xs uppercase text-[#201400] transition-all hover:bg-[#bda589] hover:text-white"
      >
        WhatsApp
      </a>
    </nav>

    <!-- Mobile burger -->
    <button
      id="menu-toggle"
      type="button"
      class="md:hidden flex flex-col gap-1.5 p-2 transition-colors"
      aria-label="Abrir menú"
      aria-controls="mobile-menu"
      aria-expanded="false"
    >
      <span class="block w-6 h-px bg-[#201400] transition-all"></span>
      <span class="block w-6 h-px bg-[#201400] transition-all"></span>
      <span class="block w-6 h-px bg-[#201400] transition-all"></span>
    </button>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden px-6 pb-6 bg-[#fdfaf7] border-t border-[#bda589]/20">
    <nav class="flex flex-col gap-4 pt-4">
      {navLinks.map(link => (
        <a
          href={link.href}
          class={`text-sm tracking-widest uppercase font-light hover:text-[#bda589] transition-colors ${currentPath.startsWith(link.href) ? 'text-[#bda589]' : 'text-[#201400]'}`}
        >
          {link.label}
        </a>
      ))}
      <a
        href={siteConfig.whatsapp}
        target="_blank"
        rel="noopener"
        class="mt-2 inline-block border border-[#bda589]/60 px-4 py-3 text-center text-sm uppercase text-[#201400] transition-all hover:bg-[#bda589] hover:text-white"
      >
        WhatsApp
      </a>
    </nav>
  </div>
</header>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');

  const setMenuOpen = (open) => {
    menu?.classList.toggle('hidden', !open);
    toggle?.setAttribute('aria-expanded', String(open));
    toggle?.setAttribute('aria-label', open ? 'Cerrar menú' : 'Abrir menú');
  };

  toggle?.addEventListener('click', () => {
    const isOpen = toggle.getAttribute('aria-expanded') === 'true';
    setMenuOpen(!isOpen);
  });

  menu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => setMenuOpen(false));
  });

  document.addEventListener('keydown', (event) => {
    if (event.key === 'Escape') {
      setMenuOpen(false);
    }
  });
</script>
