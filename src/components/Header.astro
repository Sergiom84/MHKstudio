---
import { siteConfig } from '../data/locations';

const navLinks = [
  { label: 'Inicio', href: '/' },
  { label: 'Servicios', href: '/servicios' },
  { label: 'Sobre nosotros', href: '/sobre-nosotros' },
  { label: 'Contáctanos', href: '/contacto' },
];
const currentPath = Astro.url.pathname;
const isHome = currentPath === '/';

const socialLinks = [
  {
    label: 'WhatsApp',
    href: siteConfig.whatsapp,
    icon: '<path d="M12.04 2a9.86 9.86 0 0 0-8.47 14.9L2.5 22l5.23-1.37A9.96 9.96 0 1 0 12.04 2Zm.01 1.8a8.15 8.15 0 0 1 6.9 12.5 8.17 8.17 0 0 1-10.75 2.5l-.37-.2-3.1.82.82-3.02-.23-.39A8.07 8.07 0 0 1 3.9 12a8.16 8.16 0 0 1 8.15-8.2Zm-3.3 4.3c-.18 0-.47.07-.72.34-.25.28-.95.93-.95 2.26 0 1.34.98 2.63 1.12 2.82.14.18 1.9 3.04 4.7 4.14 2.33.92 2.8.74 3.31.69.5-.05 1.64-.67 1.87-1.32.23-.65.23-1.2.16-1.32-.07-.12-.25-.18-.53-.32-.28-.14-1.64-.81-1.9-.9-.25-.1-.44-.14-.62.14-.18.27-.72.9-.88 1.08-.16.18-.32.2-.6.07-.28-.14-1.17-.43-2.23-1.38-.82-.74-1.38-1.65-1.54-1.93-.16-.28-.02-.43.12-.57.12-.12.28-.32.42-.48.14-.16.18-.28.28-.46.09-.18.04-.34-.02-.48-.07-.14-.62-1.5-.85-2.05-.22-.53-.45-.46-.62-.47h-.52Z" />',
  },
  {
    label: 'Instagram',
    href: siteConfig.instagram,
    icon: '<rect x="4" y="4" width="16" height="16" rx="5" ry="5"></rect><path d="M16.2 11.37a4.2 4.2 0 1 1-8.4 0 4.2 4.2 0 0 1 8.4 0Z"></path><path d="M17.5 6.5h.01"></path>',
  },
  {
    label: 'Facebook',
    href: siteConfig.facebook,
    icon: '<path d="M14 8h2.2V4.4A24.8 24.8 0 0 0 13 4c-3.16 0-5.32 1.93-5.32 5.45V12H4.2v4h3.48v8h4.26v-8h3.34l.53-4h-3.87V9.85C11.94 8.7 12.25 8 14 8Z" />',
  },
  {
    label: 'Pinterest',
    href: siteConfig.pinterest,
    icon: '<path d="M12.04 2.5a9.5 9.5 0 0 0-3.46 18.35c-.08-.79-.16-2 .03-2.86l1.1-4.67s-.28-.57-.28-1.4c0-1.32.76-2.3 1.7-2.3.8 0 1.2.6 1.2 1.33 0 .81-.52 2.03-.79 3.16-.22.94.47 1.7 1.4 1.7 1.68 0 2.98-1.78 2.98-4.34 0-2.27-1.63-3.86-3.96-3.86-2.7 0-4.29 2.02-4.29 4.12 0 .81.31 1.68.7 2.15.08.1.09.18.07.28l-.26 1.06c-.04.17-.14.2-.32.12-1.2-.56-1.95-2.32-1.95-3.74 0-3.04 2.2-5.82 6.35-5.82 3.34 0 5.93 2.38 5.93 5.55 0 3.32-2.1 5.99-5 5.99-.98 0-1.9-.5-2.2-1.1l-.6 2.29c-.22.86-.81 1.93-1.2 2.58A9.5 9.5 0 1 0 12.04 2.5Z" />',
  },
];
---

<header class={`fixed left-0 right-0 top-0 z-50 border-b border-[#201400]/15 ${isHome ? 'bg-[#f2eadd]/30 backdrop-blur-md' : 'bg-[#fdfaf7]/95 backdrop-blur-sm'}`}>
  <div class="flex h-[72px] w-full items-center justify-between px-6 sm:px-8 lg:h-[92px] lg:px-12 xl:px-16">
    <a href="/" class="flex items-center">
      <img src="/images/MHK.webp" alt="MHK Studio" class="h-10 w-auto lg:h-11" loading="eager" />
    </a>

    <!-- Desktop Nav -->
    <nav class="hidden items-center gap-8 lg:flex xl:gap-9">
      {navLinks.map(link => (
        <a
          href={link.href}
          class={`text-sm font-normal uppercase tracking-[0.12em] text-[#120c00] transition-colors hover:text-[#9a7d62] ${link.href === '/' ? (isHome ? 'text-[#9a7d62]' : '') : (currentPath.startsWith(link.href) ? 'text-[#9a7d62]' : '')}`}
        >
          {link.label}
        </a>
      ))}
      <div class="ml-1 flex items-center gap-6">
        {socialLinks.map((link) => (
          <a
            href={link.href}
            target="_blank"
            rel="noopener"
            aria-label={link.label}
            title={link.label}
            class="grid h-6 w-6 place-items-center text-[#120c00] transition-colors hover:text-[#9a7d62]"
          >
            <svg
              viewBox="0 0 24 24"
              aria-hidden="true"
              class="h-5 w-5"
              fill={link.label === 'Instagram' ? 'none' : 'currentColor'}
              stroke={link.label === 'Instagram' ? 'currentColor' : 'none'}
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              set:html={link.icon}
            />
          </a>
        ))}
      </div>
    </nav>

    <!-- Mobile burger -->
    <button
      id="menu-toggle"
      type="button"
      class="flex flex-col gap-1.5 p-2 transition-colors lg:hidden"
      aria-label="Abrir menú"
      aria-controls="mobile-menu"
      aria-expanded="false"
    >
      <span class="block w-6 h-px bg-[#201400] transition-all"></span>
      <span class="block w-6 h-px bg-[#201400] transition-all"></span>
      <span class="block w-6 h-px bg-[#201400] transition-all"></span>
    </button>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden border-t border-[#201400]/15 bg-[#fdfaf7]/95 px-6 pb-6 lg:hidden">
    <nav class="flex flex-col gap-4 pt-4">
      {navLinks.map(link => (
        <a
          href={link.href}
          class={`text-sm tracking-widest uppercase font-light hover:text-[#bda589] transition-colors ${link.href === '/' ? (isHome ? 'text-[#bda589]' : 'text-[#201400]') : (currentPath.startsWith(link.href) ? 'text-[#bda589]' : 'text-[#201400]')}`}
        >
          {link.label}
        </a>
      ))}
      <a
        href={siteConfig.whatsapp}
        target="_blank"
        rel="noopener"
        class="mt-2 inline-block border border-[#bda589]/60 px-4 py-3 text-center text-sm uppercase text-[#201400] transition-all hover:bg-[#bda589] hover:text-white"
      >
        WhatsApp
      </a>
      <div class="flex items-center gap-5 pt-2">
        {socialLinks.slice(1).map((link) => (
          <a
            href={link.href}
            target="_blank"
            rel="noopener"
            aria-label={link.label}
            class="grid h-8 w-8 place-items-center text-[#201400]"
          >
            <svg
              viewBox="0 0 24 24"
              aria-hidden="true"
              class="h-5 w-5"
              fill={link.label === 'Instagram' ? 'none' : 'currentColor'}
              stroke={link.label === 'Instagram' ? 'currentColor' : 'none'}
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              set:html={link.icon}
            />
          </a>
        ))}
      </div>
    </nav>
  </div>
</header>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');

  const setMenuOpen = (open) => {
    menu?.classList.toggle('hidden', !open);
    toggle?.setAttribute('aria-expanded', String(open));
    toggle?.setAttribute('aria-label', open ? 'Cerrar menú' : 'Abrir menú');
  };

  toggle?.addEventListener('click', () => {
    const isOpen = toggle.getAttribute('aria-expanded') === 'true';
    setMenuOpen(!isOpen);
  });

  menu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => setMenuOpen(false));
  });

  document.addEventListener('keydown', (event) => {
    if (event.key === 'Escape') {
      setMenuOpen(false);
    }
  });
</script>
